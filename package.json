{
  "name": "japanauto",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/extract-css.mjs && node scripts/generate-csp-hashes.mjs",
    "preview": "astro preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "audit:seo": "python3 scripts/seo-audit.py dist",
    "audit:launch": "LAUNCH=1 python3 scripts/seo-audit.py dist",
    "predeploy": "node scripts/export-catalog-data.mjs && npm run typecheck && npm test && npm run build && npm run audit:seo && npm run audit:launch",
    "deploy": "wrangler pages deploy dist --project-name japanauto",
    "astro": "astro"
  },
  "dependencies": {
    "astro": "^6.2.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260504.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "4.1.18",
    "js-yaml": "^4.1.1",
    "tailwindcss": "4.1.18",
    "typescript": "5.6",
    "vitest": "^4.1.10",
    "wrangler": "^4.87.0"
  }
}
