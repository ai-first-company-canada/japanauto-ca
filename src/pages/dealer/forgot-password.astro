---
import AuthLayout from '../../layouts/AuthLayout.astro';
---
<AuthLayout
  title="Forgot password — japanauto.ca"
  description="Reset your japanauto.ca dealer account password"
  canonical="https://japanauto.ca/dealer/forgot-password/"
>
  <h1 class="t-display-m" style="font-size:26px;line-height:32px;margin-bottom:8px">Forgot password?</h1>
  <p class="t-body-m ink-muted" style="margin-bottom:32px">
    Enter your email — we'll send you a reset link.
  </p>

  <form id="forgot-form" novalidate>
    <div class="auth-form-group">
      <label class="auth-form-label" for="email">Email</label>
      <input
        class="auth-form-input"
        id="email"
        name="email"
        type="email"
        required
        autocomplete="email"
        placeholder="you@example.ca"
      />
      <div class="auth-form-error" data-field-error="email"></div>
    </div>

    <div
      class="auth-form-error"
      data-form-error
      style="text-align:center;margin-bottom:16px"
    ></div>

    <button class="btn btn-primary auth-submit" type="submit">Send reset link</button>
  </form>

  <div class="auth-info-box" data-info-box style="display:none">
    Email password reset will be available in Phase 6 when we wire up Resend.
    For now, contact <a href="mailto:support@japanauto.ca" style="color:var(--color-accent);font-weight:500">support@japanauto.ca</a>
    for password issues.
  </div>

  <div class="auth-info-box" data-success-box style="display:none">
    If an account exists for this email, we've sent a reset link — it works once
    and expires in 1 hour. Check your spam folder too.
  </div>

  <p class="auth-link-row">
    Remember your password? <a href="/dealer/login/">Sign in</a>
  </p>

  <script is:inline>
    (function () {
      var form = document.getElementById('forgot-form');
      if (!form) return;
      var btn = form.querySelector('button[type="submit"]');
      var info = document.querySelector('[data-info-box]');
      var success = document.querySelector('[data-success-box]');

      function escapeHtml(s) {
        return String(s)
          .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
      }

      form.addEventListener('submit', async function (e) {
        e.preventDefault();
        form.querySelectorAll('[data-field-error]').forEach(function (el) { el.textContent = ''; });
        var formErr = form.querySelector('[data-form-error]');
        if (formErr) formErr.innerHTML = '';
        if (info) info.style.display = 'none';
        if (success) success.style.display = 'none';
        btn.disabled = true;
        btn.textContent = 'Sending…';

        var res = null;
        try {
          res = await fetch('/api/auth/password-reset', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email: form.email.value.trim() }),
          });
        } catch (_) {
          if (formErr) formErr.textContent = 'Network error. Check your connection.';
          btn.disabled = false;
          btn.textContent = 'Send reset link';
          return;
        }

        var err = {};
        try { err = await res.json(); } catch (_) {}

        if (res.status === 422 && Array.isArray(err.issues)) {
          var mapped = 0;
          var unmapped = [];
          err.issues.forEach(function (issue) {
            var path = issue.path && issue.path[0];
            var fieldEl = path
              ? form.querySelector('[data-field-error="' + path + '"]')
              : null;
            if (fieldEl) {
              fieldEl.textContent = issue.message;
              mapped++;
            } else {
              unmapped.push((path ? path + ': ' : '') + issue.message);
            }
          });
          if (formErr && unmapped.length) {
            formErr.innerHTML = unmapped.map(function (m) {
              return '<div>' + escapeHtml(m) + '</div>';
            }).join('');
          } else if (formErr && mapped === 0) {
            formErr.textContent = err.message || 'Validation failed';
          }
        } else if (res.status === 200) {
          // Live path (Resend configured): always the same neutral message —
          // the API never says whether the account exists.
          if (success) success.style.display = '';
          form.reset();
        } else if (res.status === 429) {
          if (formErr) formErr.textContent = err.message || 'Too many requests — try again later.';
        } else {
          // 501 dark mode (or unexpected): the manual-support fallback.
          if (info) info.style.display = '';
        }
        btn.disabled = false;
        btn.textContent = 'Send reset link';
      });
    })();
  </script>
</AuthLayout>
