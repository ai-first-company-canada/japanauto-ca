---
import AuthLayout from '../../layouts/AuthLayout.astro';
---
<AuthLayout
  title="Sign in — japanauto.ca dealer portal"
  description="Sign in to your japanauto.ca dealer account"
  canonical="https://japanauto.ca/dealer/login/"
>
  <h1 class="t-display-m" style="font-size:26px;line-height:32px;margin-bottom:8px">Sign in</h1>
  <p class="t-body-m ink-muted" style="margin-bottom:32px">to your dealer account</p>

  <form id="login-form" novalidate>
    <div class="auth-form-group">
      <label class="auth-form-label" for="email">Email</label>
      <input
        class="auth-form-input"
        id="email"
        name="email"
        type="email"
        required
        autocomplete="email"
        placeholder="you@example.ca"
      />
      <div class="auth-form-error" data-field-error="email"></div>
    </div>

    <div class="auth-form-group">
      <label class="auth-form-label" for="password">Password</label>
      <input
        class="auth-form-input"
        id="password"
        name="password"
        type="password"
        required
        minlength="8"
        autocomplete="current-password"
      />
      <div class="auth-form-error" data-field-error="password"></div>
    </div>

    <div
      class="auth-form-error"
      data-form-error
      style="text-align:center;margin-bottom:16px"
    ></div>

    <button class="btn btn-primary auth-submit" type="submit">Sign in</button>

    <p class="auth-link-row">
      <a href="/dealer/forgot-password/">Forgot password?</a>
    </p>
  </form>

  <p class="auth-link-row">
    Don't have an account? <a href="/dealer/signup/">Create one</a>
  </p>

  <script is:inline>
    (function () {
      var form = document.getElementById('login-form');
      if (!form) return;
      var btn = form.querySelector('button[type="submit"]');

      function clearErrors() {
        form.querySelectorAll('[data-field-error]').forEach(function (el) {
          el.textContent = '';
        });
        var formErr = form.querySelector('[data-form-error]');
        if (formErr) formErr.innerHTML = '';
      }

      function setFormError(msg) {
        var el = form.querySelector('[data-form-error]');
        if (el) el.textContent = msg;
      }

      function escapeHtml(s) {
        return String(s)
          .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
      }

      form.addEventListener('submit', async function (e) {
        e.preventDefault();
        clearErrors();
        btn.disabled = true;
        btn.textContent = 'Signing in…';

        var data = {
          email: form.email.value.trim(),
          password: form.password.value,
        };

        try {
          var res = await fetch('/api/auth/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          });

          if (res.ok) {
            var params = new URLSearchParams(window.location.search);
            try { sessionStorage.removeItem('jc_dealer_meta'); } catch (_) {}
            var next = params.get('next') || '/dealer/dashboard/';
            window.location.href = next;
            return;
          }

          var err = {};
          try { err = await res.json(); } catch (_) {}
          var formErr = form.querySelector('[data-form-error]');

          if (res.status === 422 && Array.isArray(err.issues)) {
            var mapped = 0;
            var unmapped = [];
            err.issues.forEach(function (issue) {
              var path = issue.path && issue.path[0];
              var fieldEl = path
                ? form.querySelector('[data-field-error="' + path + '"]')
                : null;
              if (fieldEl) {
                fieldEl.textContent = issue.message;
                mapped++;
              } else {
                unmapped.push((path ? path + ': ' : '') + issue.message);
              }
            });
            if (unmapped.length) {
              formErr.innerHTML = unmapped.map(function (m) {
                return '<div>' + escapeHtml(m) + '</div>';
              }).join('');
            } else if (mapped === 0) {
              formErr.textContent = err.message || 'Validation failed';
            }
          } else if (res.status === 401) {
            setFormError('Invalid email or password');
          } else if (res.status === 429) {
            setFormError('Too many attempts. Wait a few minutes and try again.');
          } else if (res.status >= 500) {
            setFormError('Server error (' + res.status + '). Try again in a moment.');
          } else {
            setFormError(err.message || 'Sign in failed (HTTP ' + res.status + ').');
          }
          console.error('Auth error:', res.status, err);
        } catch (_) {
          setFormError('Network error. Check your connection.');
        } finally {
          btn.disabled = false;
          btn.textContent = 'Sign in';
        }
      });
    })();
  </script>
</AuthLayout>
