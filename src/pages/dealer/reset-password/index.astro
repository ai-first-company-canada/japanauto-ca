---
import AuthLayout from '../../../layouts/AuthLayout.astro';
---
<AuthLayout
  title="Reset password — japanauto.ca"
  description="Set a new password for your dealer account"
  canonical="https://japanauto.ca/dealer/reset-password/"
>
  <h1 class="t-display-m" style="font-size:26px;line-height:32px;margin-bottom:8px">Reset password</h1>
  <p class="t-body-m ink-muted" style="margin-bottom:32px">
    Choose a new password for your dealer account.
  </p>

  <form id="reset-form" novalidate>
    <div class="auth-form-group">
      <label class="auth-form-label" for="password">New password</label>
      <input
        class="auth-form-input"
        id="password"
        name="password"
        type="password"
        required
        minlength="10"
        autocomplete="new-password"
      />
      <div class="auth-form-error" data-field-error="new_password">Use 10 or more characters</div>
    </div>

    <div class="auth-form-group">
      <label class="auth-form-label" for="confirm">Confirm password</label>
      <input
        class="auth-form-input"
        id="confirm"
        name="confirm"
        type="password"
        required
        minlength="10"
        autocomplete="new-password"
      />
      <div class="auth-form-error" data-field-error="confirm"></div>
    </div>

    <div
      class="auth-form-error"
      data-form-error
      style="text-align:center;margin-bottom:16px"
    ></div>

    <button class="btn btn-primary auth-submit" type="submit">Set new password</button>
  </form>

  <div class="auth-info-box" data-success-box style="display:none">
    ✓ Password updated. All previous sessions were signed out.
    <a href="/dealer/login/" style="color:var(--color-accent);font-weight:600">Sign in with your new password →</a>
  </div>

  <p class="auth-link-row">
    <a href="/dealer/login/">Back to sign in</a>
  </p>

  <script is:inline>
    (function () {
      var form = document.getElementById('reset-form');
      if (!form) return;
      var btn = form.querySelector('button[type="submit"]');
      var success = document.querySelector('[data-success-box]');
      var formErr = form.querySelector('[data-form-error]');
      var params = new URLSearchParams(window.location.search);
      var token = params.get('token') || '';

      // No usable token in the URL → the form can't succeed; say so upfront.
      if (token.length < 20) {
        if (formErr) formErr.textContent =
          'This reset link is incomplete — request a new one from support@japanauto.ca.';
        if (btn) btn.disabled = true;
      }

      form.addEventListener('submit', async function (e) {
        e.preventDefault();
        form.querySelectorAll('[data-field-error]').forEach(function (el) { el.textContent = ''; });
        if (formErr) formErr.textContent = '';

        if (form.password.value !== form.confirm.value) {
          var fieldEl = form.querySelector('[data-field-error="confirm"]');
          if (fieldEl) fieldEl.textContent = 'Passwords do not match';
          return;
        }

        btn.disabled = true;
        btn.textContent = 'Saving…';
        try {
          var res = await fetch('/api/auth/password-reset/confirm', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ token: token, new_password: form.password.value }),
          });
          if (res.ok) {
            form.style.display = 'none';
            if (success) success.style.display = '';
            return;
          }
          var data = await res.json().catch(function () { return {}; });
          if (res.status === 422 && data.issues && data.issues.length) {
            var msg = data.issues[0].message || 'Invalid input';
            var slot = form.querySelector('[data-field-error="new_password"]');
            if (slot) slot.textContent = msg;
          } else if (formErr) {
            formErr.textContent = data.message ||
              'This reset link is invalid or has expired — request a new one.';
          }
        } catch (_) {
          if (formErr) formErr.textContent = 'Network error — please try again.';
        }
        btn.disabled = false;
        btn.textContent = 'Set new password';
      });
    })();
  </script>
</AuthLayout>
