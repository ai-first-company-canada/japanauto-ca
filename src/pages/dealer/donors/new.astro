---
import DealerLayout from '../../../layouts/DealerLayout.astro';
import DonorForm from '../../../components/sections/DonorForm.astro';
---
<DealerLayout
  title="New donor car — japanauto.ca"
  canonical="https://japanauto.ca/dealer/donors/new/"
  activeTab="donors"
>
  <a
    href="/dealer/donors/"
    style="font-size:13px;color:var(--color-ink-muted);margin-bottom:8px;display:inline-block"
  >← Back to donors</a>
  <h1 class="t-display-m" style="font-size:26px;margin-bottom:24px">New donor car</h1>
  <DonorForm mode="create" />
</DealerLayout>
