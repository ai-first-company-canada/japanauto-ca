---
import DealerLayout from '../../../layouts/DealerLayout.astro';
---
<DealerLayout
  title="My donor cars — japanauto.ca"
  canonical="https://japanauto.ca/dealer/donors/"
  activeTab="donors"
>
  <div
    style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px"
  >
    <h1 class="t-display-m" style="font-size:26px;line-height:32px">My donor cars</h1>
    <a href="/dealer/donors/new/" class="btn btn-primary btn-sm">+ New</a>
  </div>

  <div
    data-status-tabs
    style="display:flex;gap:4px;margin-bottom:20px;border-bottom:1px solid var(--color-divider)"
  >
    <button class="status-tab active" type="button" data-status="active">
      Active <span data-count-active class="num">—</span>
    </button>
    <button class="status-tab" type="button" data-status="draft">
      Drafts <span data-count-draft class="num">—</span>
    </button>
    <button class="status-tab" type="button" data-status="depleted">
      Depleted <span data-count-depleted class="num">—</span>
    </button>
    <button class="status-tab" type="button" data-status="expired">
      Expired <span data-count-expired class="num">—</span>
    </button>
  </div>

  <div
    data-donors-table
    style="display:flex;flex-direction:column;gap:8px"
  >
    <p class="t-body-s ink-muted">Loading…</p>
  </div>

  <script is:inline>
    (function () {
      var allDonors = [];
      var activeStatus = 'active';

      function escapeHtml(s) {
        return String(s)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;');
      }

      function buildLiveHref(d) {
        if (d.status !== 'active' && d.status !== 'depleted') return null;
        return '/parts/listing/' + encodeURIComponent(d.slug || '') + '/';
      }

      function render() {
        var filtered = allDonors.filter(function (d) {
          return (d.status || 'active') === activeStatus;
        });
        var container = document.querySelector('[data-donors-table]');
        if (!container) return;
        if (filtered.length === 0) {
          if (allDonors.length === 0) {
            container.innerHTML =
              '<div class="card" style="padding:24px;text-align:center">' +
              '<p class="t-body-m" style="margin-bottom:12px">No donor cars yet.</p>' +
              '<a href="/dealer/donors/new/" class="btn btn-primary btn-sm">Add your first donor →</a>' +
              '</div>';
          } else {
            container.innerHTML =
              '<p class="t-body-s ink-muted" style="padding:32px 0;text-align:center">No ' +
              escapeHtml(activeStatus) + ' donor cars.</p>';
          }
          return;
        }
        container.innerHTML = filtered.map(function (d) {
          var make = d.make_name || d.make_slug || '';
          var model = d.model_name || d.model_slug || '';
          var trim = d.trim ? ' ' + d.trim : '';
          var color = d.color_exterior ? ' · ' + d.color_exterior : '';
          var km = Number(d.mileage || 0).toLocaleString('en-US');
          var id = encodeURIComponent(d.id);
          var live = buildLiveHref(d);
          var canMarkDepleted = d.status === 'active' && d.condition !== 'depleted';
          var liveLink = live
            ? '<a href="' + escapeHtml(live) + '" target="_blank" rel="noreferrer" ' +
              'style="font-size:11px;color:var(--color-accent);text-decoration:underline">View live</a>'
            : '<span class="t-body-s ink-muted" style="font-size:11px">—</span>';
          var depleteBtn = canMarkDepleted
            ? '<button type="button" class="btn btn-sm" data-deplete-id="' + escapeHtml(d.id) +
              '" style="padding:0 10px;height:36px;font-size:12px;background:#fff;color:var(--color-ink-muted);border:1px solid var(--color-divider)">Mark depleted</button>'
            : '';
          return (
            '<div class="card" style="padding:14px;display:flex;flex-direction:column;gap:8px">' +
            '<div style="display:flex;justify-content:space-between;align-items:flex-start;gap:12px">' +
            '<div style="flex:1;min-width:0">' +
            '<div class="t-h-s" style="font-size:14px;line-height:20px">' +
            escapeHtml(d.year + ' ' + make + ' ' + model + trim) + '</div>' +
            '<div class="t-body-s ink-muted" style="font-size:12px;line-height:16px;margin-top:2px">' +
            '<span class="num">' + km + '</span> km' + escapeHtml(color) + ' · ' +
            escapeHtml(d.city_slug || '') +
            '</div>' +
            '</div>' +
            '<div style="font-size:11px;color:var(--color-ink-muted);text-transform:uppercase">' +
            escapeHtml(d.condition || '') + '</div>' +
            '</div>' +
            '<div style="display:flex;justify-content:space-between;align-items:center;gap:8px">' +
            liveLink +
            '<div style="display:flex;gap:6px;flex-shrink:0">' +
            depleteBtn +
            '<a href="/dealer/donors/edit/?id=' + id +
            '" class="btn btn-secondary btn-sm" style="padding:0 12px;height:36px;font-size:12px">Edit</a>' +
            '<button type="button" class="btn btn-sm" data-delete-id="' + escapeHtml(d.id) +
            '" style="padding:0 12px;height:36px;font-size:12px;background:#fff;color:var(--color-accent);border:1px solid var(--color-accent)">Delete</button>' +
            '</div>' +
            '</div>' +
            '</div>'
          );
        }).join('');

        container.querySelectorAll('[data-delete-id]').forEach(function (btn) {
          btn.addEventListener('click', async function () {
            var id = btn.getAttribute('data-delete-id');
            if (!confirm('Delete this donor? It will be moved to Expired.')) return;
            btn.disabled = true;
            var res = await fetch('/api/donors/' + encodeURIComponent(id), {
              method: 'DELETE',
            });
            if (res.ok || res.status === 204) {
              allDonors = allDonors.map(function (d) {
                return d.id === id ? Object.assign({}, d, { status: 'expired' }) : d;
              });
              updateCounts();
              render();
            } else {
              alert('Failed to delete donor.');
              btn.disabled = false;
            }
          });
        });

        container.querySelectorAll('[data-deplete-id]').forEach(function (btn) {
          btn.addEventListener('click', async function () {
            var id = btn.getAttribute('data-deplete-id');
            if (!confirm('Mark this donor as fully parted out (depleted)?')) return;
            btn.disabled = true;
            var res = await fetch(
              '/api/donors/' + encodeURIComponent(id) + '/mark-depleted',
              { method: 'POST' },
            );
            if (res.ok || res.status === 409) {
              allDonors = allDonors.map(function (d) {
                return d.id === id
                  ? Object.assign({}, d, { status: 'depleted', condition: 'depleted' })
                  : d;
              });
              updateCounts();
              render();
            } else {
              alert('Failed to mark depleted.');
              btn.disabled = false;
            }
          });
        });
      }

      function updateCounts() {
        var counts = { active: 0, draft: 0, depleted: 0, expired: 0, flagged: 0 };
        allDonors.forEach(function (d) {
          var s = d.status || 'active';
          if (counts[s] !== undefined) counts[s]++;
        });
        var setNum = function (sel, n) {
          var el = document.querySelector(sel);
          if (el) el.textContent = String(n);
        };
        setNum('[data-count-active]', counts.active);
        setNum('[data-count-draft]', counts.draft);
        setNum('[data-count-depleted]', counts.depleted);
        setNum('[data-count-expired]', counts.expired);
      }

      document.querySelectorAll('.status-tab').forEach(function (tab) {
        tab.addEventListener('click', function () {
          document.querySelectorAll('.status-tab').forEach(function (t) {
            t.classList.remove('active');
          });
          tab.classList.add('active');
          activeStatus = tab.getAttribute('data-status');
          render();
        });
      });

      (async function load() {
        try {
          var res = await fetch('/api/donors?dealer_id=me&limit=200');
          if (res.status === 401) {
            window.location.href = '/dealer/login/?next=/dealer/donors/';
            return;
          }
          if (res.status === 403) {
            var c = document.querySelector('[data-donors-table]');
            if (c) {
              c.innerHTML =
                '<p class="t-body-m" style="padding:32px;text-align:center">' +
                'This page is for salvage yards. Switch your account type in ' +
                '<a href="/dealer/profile/">profile</a> to list donor cars.' +
                '</p>';
            }
            return;
          }
          if (!res.ok) throw new Error('donors fetch failed: ' + res.status);
          var data = await res.json();
          allDonors = data.donors || [];
          updateCounts();
          render();
        } catch (e) {
          console.error(e);
          var c = document.querySelector('[data-donors-table]');
          if (c) {
            c.innerHTML =
              '<p class="t-body-s" style="color:var(--color-accent);padding:32px 0;text-align:center">Failed to load donors.</p>';
          }
        }
      })();
    })();
  </script>
</DealerLayout>
