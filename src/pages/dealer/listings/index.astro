---
import DealerLayout from '../../../layouts/DealerLayout.astro';
import StatsModal from '../../../components/sections/StatsModal.astro';
---
<DealerLayout
  title="My listings — japanauto.ca"
  canonical="https://japanauto.ca/dealer/listings/"
  activeTab="listings"
>
  <div
    style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px"
  >
    <h1 class="t-display-m" style="font-size:26px;line-height:32px">My listings</h1>
    <a href="/dealer/listings/new/" class="btn btn-primary btn-sm">+ New</a>
  </div>

  <div
    data-status-tabs
    style="display:flex;gap:4px;margin-bottom:20px;border-bottom:1px solid var(--color-divider)"
  >
    <button class="status-tab active" type="button" data-status="active">
      Active <span data-count-active class="num">—</span>
    </button>
    <button class="status-tab" type="button" data-status="sold">
      Sold <span data-count-sold class="num">—</span>
    </button>
    <button class="status-tab" type="button" data-status="expired">
      Expired <span data-count-expired class="num">—</span>
    </button>
    <button class="status-tab" type="button" data-status="draft">
      Drafts <span data-count-draft class="num">—</span>
    </button>
  </div>

  <div
    data-listings-table
    style="display:flex;flex-direction:column;gap:8px"
  >
    <p class="t-body-s ink-muted">Loading…</p>
  </div>

  <script is:inline>
    (function () {
      var allListings = [];
      var activeStatus = 'active';
      var socialJobs = {}; // listing_id -> latest job (Feature 3)

      var CONSENT_TEXT =
        'Promote this listing on japanauto.ca social channels?\n\n' +
        'You allow japanauto.ca to use this listing’s photos and details to ' +
        'create promotional posts (Instagram, TikTok, etc.). Published links ' +
        'will appear here. Promotion is free during the launch period.';

      function escapeHtml(s) {
        return String(s)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;');
      }

      function render() {
        var filtered = allListings.filter(function (l) {
          return (l.status || 'active') === activeStatus;
        });
        var container = document.querySelector('[data-listings-table]');
        if (!container) return;
        if (filtered.length === 0) {
          container.innerHTML =
            '<p class="t-body-s ink-muted" style="padding:32px 0;text-align:center">No ' +
            escapeHtml(activeStatus) + ' listings.</p>';
          return;
        }
        container.innerHTML = filtered.map(function (l) {
          var make = l.make_name || l.make_slug || '';
          var model = l.model_name || l.model_slug || '';
          var trim = l.trim ? ' ' + l.trim : '';
          var dollars = (Number(l.price || 0) / 100).toLocaleString('en-US');
          var km = Number(l.mileage || 0).toLocaleString('en-US');
          var id = encodeURIComponent(l.id);
          var job = socialJobs[l.id];
          var socialLine = '';
          if (job && job.status === 'published' && job.result_links.length) {
            socialLine = '<div class="t-body-s" style="font-size:12px;line-height:16px;margin-top:2px;color:var(--color-ink-muted)">Social: published — ' +
              job.result_links.map(function (u, i) {
                return '<a href="' + escapeHtml(u) + '" target="_blank" rel="noreferrer" style="color:var(--color-ink-strong)">post ' + (i + 1) + '</a>';
              }).join(', ') + '</div>';
          } else if (job && (job.status === 'requested' || job.status === 'in_production')) {
            socialLine = '<div class="t-body-s ink-muted" style="font-size:12px;line-height:16px;margin-top:2px">Social: ' +
              (job.status === 'requested' ? 'queued for promotion' : 'post in production') + '</div>';
          }
          var promoteBtn = (l.status === 'active' && (!job || job.status === 'cancelled'))
            ? '<button type="button" class="btn btn-sm" data-promote-id="' + escapeHtml(l.id) +
              '" style="padding:0 12px;height:36px;font-size:12px;background:#fff;color:var(--color-ink-strong);border:1px solid var(--color-divider)">Promote</button>'
            : '';
          return (
            '<div class="card" style="padding:14px;display:flex;justify-content:space-between;align-items:center;gap:12px">' +
            '<div style="flex:1;min-width:0">' +
            '<div class="t-h-s" style="font-size:14px;line-height:20px">' +
            escapeHtml(l.year + ' ' + make + ' ' + model + trim) + '</div>' +
            '<div class="t-body-s ink-muted" style="font-size:12px;line-height:16px;margin-top:2px">' +
            'CA$<span class="num">' + dollars + '</span> · ' +
            '<span class="num">' + km + '</span> km' +
            '</div>' +
            socialLine +
            '</div>' +
            '<div style="display:flex;gap:6px;flex-shrink:0">' +
            promoteBtn +
            '<button type="button" class="btn btn-sm" data-stats-id="' + escapeHtml(l.id) +
            '" data-stats-title="' + escapeHtml(l.year + ' ' + make + ' ' + model + trim) +
            '" style="padding:0 12px;height:36px;font-size:12px;background:#fff;color:var(--color-ink-strong);border:1px solid var(--color-divider)">Stats</button>' +
            '<a href="/dealer/listings/edit/?id=' + id +
            '" class="btn btn-secondary btn-sm" style="padding:0 12px;height:36px;font-size:12px">Edit</a>' +
            '<button type="button" class="btn btn-sm" data-delete-id="' + escapeHtml(l.id) +
            '" style="padding:0 12px;height:36px;font-size:12px;background:#fff;color:var(--color-accent);border:1px solid var(--color-accent)">Delete</button>' +
            '</div>' +
            '</div>'
          );
        }).join('');

        container.querySelectorAll('[data-stats-id]').forEach(function (btn) {
          btn.addEventListener('click', function () {
            window.jcOpenStats('listing', btn.getAttribute('data-stats-id'),
              btn.getAttribute('data-stats-title'));
          });
        });

        container.querySelectorAll('[data-promote-id]').forEach(function (btn) {
          btn.addEventListener('click', async function () {
            var id = btn.getAttribute('data-promote-id');
            if (!confirm(CONSENT_TEXT)) return;
            btn.disabled = true;
            try {
              var res = await fetch('/api/listings/' + encodeURIComponent(id) + '/boost-social', { method: 'POST' });
              if (res.status === 403) {
                var err = await res.json().catch(function () { return {}; });
                alert(err.message || 'Social promotion is a Pro feature.');
                btn.disabled = false;
                return;
              }
              if (res.status === 409) {
                alert('This listing is already queued for promotion.');
                btn.disabled = false;
                return;
              }
              if (!res.ok) { alert('Failed to queue promotion — try again.'); btn.disabled = false; return; }
              var data = await res.json();
              socialJobs[id] = { status: 'requested', result_links: [], requested_at: data.job.requested_at };
              render();
            } catch (_) {
              alert('Network error — try again.');
              btn.disabled = false;
            }
          });
        });

        container.querySelectorAll('[data-delete-id]').forEach(function (btn) {
          btn.addEventListener('click', async function () {
            var id = btn.getAttribute('data-delete-id');
            if (!confirm('Delete this listing? It will be moved to Expired.')) return;
            btn.disabled = true;
            var res = await fetch('/api/listings/' + encodeURIComponent(id), {
              method: 'DELETE',
            });
            if (res.ok) {
              // Soft-delete: API sets status='expired'. Reflect locally.
              allListings = allListings.map(function (l) {
                return l.id === id ? Object.assign({}, l, { status: 'expired' }) : l;
              });
              updateCounts();
              render();
            } else {
              alert('Failed to delete listing.');
              btn.disabled = false;
            }
          });
        });
      }

      function updateCounts() {
        var counts = { active: 0, sold: 0, expired: 0, draft: 0, flagged: 0 };
        allListings.forEach(function (l) {
          var s = l.status || 'active';
          if (counts[s] !== undefined) counts[s]++;
        });
        var setNum = function (sel, n) {
          var el = document.querySelector(sel);
          if (el) el.textContent = String(n);
        };
        setNum('[data-count-active]', counts.active);
        setNum('[data-count-sold]', counts.sold);
        setNum('[data-count-expired]', counts.expired);
        setNum('[data-count-draft]', counts.draft);
      }

      document.querySelectorAll('.status-tab').forEach(function (tab) {
        tab.addEventListener('click', function () {
          document.querySelectorAll('.status-tab').forEach(function (t) {
            t.classList.remove('active');
          });
          tab.classList.add('active');
          activeStatus = tab.getAttribute('data-status');
          render();
        });
      });

      (async function load() {
        try {
          var res = await fetch('/api/listings?dealer_id=me&limit=200');
          if (res.status === 401) {
            window.location.href = '/dealer/login/?next=/dealer/listings/';
            return;
          }
          if (!res.ok) throw new Error('listings fetch failed: ' + res.status);
          var data = await res.json();
          allListings = data.listings || data.items || [];
          // Social-boost statuses (Feature 3) — jobs come newest-first, so the
          // first one seen per listing is the latest. Failure is non-fatal.
          try {
            var jr = await fetch('/api/social/jobs/mine');
            if (jr.ok) {
              (await jr.json()).jobs.forEach(function (j) {
                if (!socialJobs[j.listing_id]) socialJobs[j.listing_id] = j;
              });
            }
          } catch (_) { /* render without social statuses */ }
          updateCounts();
          render();
        } catch (e) {
          console.error(e);
          var c = document.querySelector('[data-listings-table]');
          if (c) {
            c.innerHTML =
              '<p class="t-body-s" style="color:var(--color-accent);padding:32px 0;text-align:center">Failed to load listings.</p>';
          }
        }
      })();
    })();
  </script>

  <StatsModal />
</DealerLayout>
