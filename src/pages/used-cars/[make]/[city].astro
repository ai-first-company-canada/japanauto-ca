---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Navbar from '../../../components/sections/Navbar.astro';
import MenuDrawer from '../../../components/sections/MenuDrawer.astro';
import CityPickerDialog from '../../../components/sections/CityPickerDialog.astro';
import Footer from '../../../components/sections/Footer.astro';
import Breadcrumb from '../../../components/atoms/Breadcrumb.astro';
import PageHeading from '../../../components/sections/PageHeading.astro';
import ModelsGridSection from '../../../components/sections/ModelsGridSection.astro';
import AboutBrandSection from '../../../components/sections/AboutBrandSection.astro';
import FaqSection from '../../../components/sections/FaqSection.astro';
import CrossLinksBand from '../../../components/sections/CrossLinksBand.astro';
import { BRAND_CONTENT, TIER_1_CITIES } from '../../../data/brand-content';
import { getModelsForCity } from '../../../data/models-stubs';

export function getStaticPaths() {
  const brands = Object.keys(BRAND_CONTENT);
  const cities = TIER_1_CITIES.map((c) => c.slug);
  return brands.flatMap((make) =>
    cities.map((city) => ({ params: { make, city } })),
  );
}

const { make, city } = Astro.params;
const brand = BRAND_CONTENT[make!]!;
const cityInfo = TIER_1_CITIES.find((c) => c.slug === city)!;
const models = getModelsForCity(make!, city!);
const cityFactor = cityInfo.count / 1284;
const totalCount = Math.max(3, Math.round(brand.totalCount * cityFactor));
const dealerCount = Math.max(3, Math.round(brand.dealerCount * cityFactor));

const title = `Used ${brand.name} in ${cityInfo.name}, ${cityInfo.province} — japanauto.ca`;
const description = `Find used ${brand.name} cars in ${cityInfo.name}. ${totalCount} ${brand.name} listings from ${dealerCount} local dealers. AMVIC-verified, VIN-checked.`;
const canonical = `https://japanauto.ca/used-cars/${make}/${city}/`;

const schemaLD = [
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://japanauto.ca/' },
      { '@type': 'ListItem', position: 2, name: cityInfo.name, item: canonical },
      { '@type': 'ListItem', position: 3, name: brand.name, item: `https://japanauto.ca/used-cars/${make}/` },
    ],
  },
  {
    '@type': 'ItemList',
    name: `${brand.name} models available in ${cityInfo.name}`,
    itemListElement: models.map((m, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: `${brand.name} ${m.name}`,
      url: `https://japanauto.ca/used-cars/${make}/${m.slug}/${city}/`,
    })),
  },
  {
    '@type': 'Place',
    name: cityInfo.name,
    address: {
      '@type': 'PostalAddress',
      addressLocality: cityInfo.name,
      addressRegion: cityInfo.province,
      addressCountry: 'CA',
    },
  },
];

const subtitleHtml = `<span class="num">${totalCount}</span> used ${brand.name} cars from <span class="num">${dealerCount}</span> dealers · Updated today`;
---
<BaseLayout
  {title}
  {description}
  {canonical}
  {schemaLD}
  geoFallbackCity={city!}
>
  <Navbar slot="navbar" cityShort={`${cityInfo.name}, ${cityInfo.province}`} />
  <MenuDrawer slot="menu-drawer" cityShort={`${cityInfo.name}, ${cityInfo.province}`} cityName={cityInfo.name} />
  <CityPickerDialog slot="city-picker" />
  <Footer slot="footer" />

  <h1 class="sr-only">{`Used ${brand.name} in ${cityInfo.name}, ${cityInfo.province}`}</h1>

  <Breadcrumb items={[
    { label: 'Home', href: '/' },
    { label: cityInfo.name },
    { label: brand.name, href: `/used-cars/${make}/` },
  ]} />

  <PageHeading
    title={`${brand.name} models in ${cityInfo.name}`}
    subtitle={subtitleHtml}
  />

  <ModelsGridSection models={models} brandSlug={make!} citySlug={city!} />

  <AboutBrandSection title={brand.aboutTitle} paragraphs={brand.aboutParagraphs} />

  <FaqSection items={brand.faqs} heading={`Common questions about ${brand.name}`} />

  <CrossLinksBand
    brandSlug={make!}
    brandName={brand.name}
    currentCitySlug={city!}
    citiesList={TIER_1_CITIES}
  />
</BaseLayout>
