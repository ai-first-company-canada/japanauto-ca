---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Navbar from '../../../components/sections/Navbar.astro';
import MenuDrawer from '../../../components/sections/MenuDrawer.astro';
import CityPickerDialog from '../../../components/sections/CityPickerDialog.astro';
import Footer from '../../../components/sections/Footer.astro';
import Breadcrumb from '../../../components/atoms/Breadcrumb.astro';
import PageHeading from '../../../components/sections/PageHeading.astro';
import AboutBrandSection from '../../../components/sections/AboutBrandSection.astro';
import FaqSection from '../../../components/sections/FaqSection.astro';
import { BRAND_CONTENT, TIER_1_CITIES } from '../../../data/brand-content';
import { liveCounts } from '../../../data/live-counts';
import { faqPage } from '../../../lib/schema-graph';

export function getStaticPaths() {
  return Object.keys(BRAND_CONTENT).map((make) => ({ params: { make } }));
}

const { make } = Astro.params;
const brand = BRAND_CONTENT[make!]!;

const brandListings = liveCounts.brand(make!);
const brandDealers = liveCounts.brandDealers(make!);

const cityCards = TIER_1_CITIES.map((c) => ({
  slug: c.slug,
  name: c.name,
  province: c.province,
  count: liveCounts.cityBrand(c.slug, make!),
}));

const title = `Used ${brand.name} cars across Canada — japanauto.ca`;
const description = brandListings > 0
  ? `Used ${brand.name} cars in ${TIER_1_CITIES.length} major Canadian cities. ${brandListings} live listing${brandListings === 1 ? '' : 's'} from AMVIC-licensed dealers, every VIN checked.`
  : `Used ${brand.name} cars across Canada's major cities. Live listings from AMVIC-licensed dealers appear as partners onboard — every VIN checked.`;
const canonical = `https://japanauto.ca/used-cars/${make}/`;

const faqLd = faqPage(brand.faqs.map((f) => f.q), brand.faqs.map((f) => f.a));
const schemaLD = [
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://japanauto.ca/' },
      { '@type': 'ListItem', position: 2, name: brand.name, item: canonical },
    ],
  },
  ...(faqLd ? [faqLd] : []),
  {
    '@type': 'ItemList',
    name: `${brand.name} availability across Canada`,
    itemListElement: cityCards.map((c, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: `${brand.name} in ${c.name}`,
      url: `https://japanauto.ca/${c.slug}/${make}/`,
    })),
  },
  {
    '@type': 'Brand',
    name: brand.name,
    description: brand.aboutParagraphs[0] ?? `${brand.name} cars available across Canada.`,
  },
];

const subtitleHtml = brandListings > 0
  ? `<span class="num">${brandListings}</span> live ${brand.name} listing${brandListings === 1 ? '' : 's'} from <span class="num">${brandDealers}</span> AMVIC-licensed dealer${brandDealers === 1 ? '' : 's'}`
  : `Live ${brand.name} listings appear here as AMVIC-licensed dealers onboard across <span class="num">${TIER_1_CITIES.length}</span> Canadian cities`;
---
<BaseLayout {title} {description} {canonical} {schemaLD}>
  <Navbar slot="navbar" />
  <MenuDrawer slot="menu-drawer" />
  <CityPickerDialog slot="city-picker" />
  <Footer slot="footer" />

  <h1 class="sr-only">{`Used ${brand.name} cars across Canada`}</h1>

  <Breadcrumb items={[
    { label: 'Home', href: '/' },
    { label: brand.name },
  ]} />

  <PageHeading
    title={`${brand.name} cars across Canada`}
    subtitle={subtitleHtml}
  />

  {/* Inlined city directory (was CityDirectoryGrid): identical markup, but a
      zero count renders honest onboarding copy instead of "0 cars". */}
  <section style="padding:0 16px 32px">
    <h2 class="sr-only">{`${brand.name} availability across Canadian cities`}</h2>
    <div style="display:grid;grid-template-columns:repeat(2, 1fr);gap:12px">
      {cityCards.map((c) => (
        <a
          href={`/${c.slug}/${make}/`}
          class="card"
          style="display:flex;flex-direction:column;justify-content:space-between;padding:20px;min-height:96px;text-align:left"
        >
          <h3 class="t-h-m" style="font-size:17px">{c.name}</h3>
          <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-top:auto;gap:8px">
            {c.count > 0 ? (
              <span class="t-caption" style="font-size:10px">
                <span class="num">{c.count.toLocaleString('en-US')}</span> cars
              </span>
            ) : (
              <span class="t-caption" style="font-size:10px">Dealers onboarding</span>
            )}
            <span class="t-caption t-mono" style="font-size:10px">{c.province}</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <AboutBrandSection title={brand.aboutTitle} paragraphs={brand.aboutParagraphs} />

  <FaqSection items={brand.faqs} heading={`Common questions about ${brand.name}`} />
</BaseLayout>
