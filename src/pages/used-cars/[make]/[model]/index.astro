---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Navbar from '../../../../components/sections/Navbar.astro';
import MenuDrawer from '../../../../components/sections/MenuDrawer.astro';
import CityPickerDialog from '../../../../components/sections/CityPickerDialog.astro';
import Footer from '../../../../components/sections/Footer.astro';
import Breadcrumb from '../../../../components/atoms/Breadcrumb.astro';
import PageHeading from '../../../../components/sections/PageHeading.astro';
import CityDirectoryGrid from '../../../../components/sections/CityDirectoryGrid.astro';
import AboutBrandSection from '../../../../components/sections/AboutBrandSection.astro';
import FaqSection from '../../../../components/sections/FaqSection.astro';
import { BRAND_CONTENT, TIER_1_CITIES } from '../../../../data/brand-content';
import { MODELS_BY_BRAND } from '../../../../data/models-stubs';
import { liveCounts } from '../../../../data/live-counts';

export function getStaticPaths() {
  const paths: Array<{ params: { make: string; model: string } }> = [];
  for (const make of Object.keys(MODELS_BY_BRAND)) {
    for (const model of MODELS_BY_BRAND[make]!) {
      paths.push({ params: { make, model: model.slug } });
    }
  }
  return paths;
}

const { make, model } = Astro.params;
const brand = BRAND_CONTENT[make!]!;
const modelInfo = MODELS_BY_BRAND[make!]!.find((m) => m.slug === model)!;

const cityCards = TIER_1_CITIES.map((c) => ({
  slug: c.slug,
  name: c.name,
  province: c.province,
  count: liveCounts.cityModel(c.slug, make!, model!),
}));

const totalListings = liveCounts.brandModel(make!, model!);
const citiesLive = cityCards.filter((c) => c.count > 0);
const citiesOnboarding = cityCards.filter((c) => c.count === 0);

const title = `Used ${brand.name} ${modelInfo.name} across Canada — japanauto.ca`;
const description = totalListings > 0
  ? `Used ${brand.name} ${modelInfo.name} for sale across Canada — ${totalListings} live listing${totalListings === 1 ? '' : 's'} from AMVIC-licensed, VIN-checked local dealers.`
  : `Used ${brand.name} ${modelInfo.name} across Canada — live listings from AMVIC-licensed dealers, added as local sellers onboard. Every listing is a real car.`;
const canonical = `https://japanauto.ca/used-cars/${make}/${model}/`;

const aboutTitle = `About the ${brand.name} ${modelInfo.name}`;
const aboutParagraphs = [
  `japanauto.ca tracks used ${brand.name} ${modelInfo.name} listings from licensed Canadian dealers. Every listing is a real car — buyers compare by year, mileage, and trim against city-local pricing.`,
  `Used ${modelInfo.name} listings cover the site's rolling 10-year eligibility window. Inventory is live and growing as AMVIC-licensed dealers onboard — pick a city below to browse local availability.`,
];

const modelFaqs = [
  {
    q: `Is the ${brand.name} ${modelInfo.name} a good used buy?`,
    a: `${brand.name} consistently leads its segment for resale value and long-term reliability. Inventory is live and growing as AMVIC-licensed dealers onboard — every ${modelInfo.name} listing is a real car from a licensed local seller.`,
  },
  {
    q: `Which Canadian city has the most used ${brand.name} ${modelInfo.name}?`,
    a: `That shifts as dealers onboard. Each city page below shows live ${modelInfo.name} availability for that market — every listing comes from a licensed local seller.`,
  },
  {
    q: `What's the average price for a used ${brand.name} ${modelInfo.name}?`,
    a: `Pricing depends on year, mileage, trim, and city. Pick a city below to see real asking prices from licensed dealers as live listings arrive.`,
  },
];

const schemaLD = [
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://japanauto.ca/' },
      { '@type': 'ListItem', position: 2, name: brand.name, item: `https://japanauto.ca/used-cars/${make}/` },
      { '@type': 'ListItem', position: 3, name: modelInfo.name, item: canonical },
    ],
  },
  {
    '@type': 'ItemList',
    name: `${brand.name} ${modelInfo.name} availability across Canada`,
    itemListElement: cityCards.map((c, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: `${brand.name} ${modelInfo.name} in ${c.name}`,
      url: `https://japanauto.ca/${c.slug}/${make}/${model}/`,
    })),
  },
  {
    '@type': 'FAQPage',
    mainEntity: modelFaqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
];

const subtitleHtml = totalListings > 0
  ? `<span class="num">${totalListings}</span> ${modelInfo.name} listing${totalListings === 1 ? '' : 's'} across <span class="num">${citiesLive.length}</span> Canadian ${citiesLive.length === 1 ? 'city' : 'cities'} · Updated today`
  : `Live ${modelInfo.name} listings appear here as local dealers onboard`;
---
<BaseLayout {title} {description} {canonical} {schemaLD}>
  <Navbar slot="navbar" />
  <MenuDrawer slot="menu-drawer" />
  <CityPickerDialog slot="city-picker" />
  <Footer slot="footer" />

  <h1 class="sr-only">{`Used ${brand.name} ${modelInfo.name} across Canada`}</h1>

  <Breadcrumb items={[
    { label: 'Home', href: '/' },
    { label: brand.name, href: `/used-cars/${make}/` },
    { label: modelInfo.name },
  ]} />

  <PageHeading
    title={`${brand.name} ${modelInfo.name} across Canada`}
    subtitle={subtitleHtml}
  />

  {citiesLive.length > 0 && (
    <CityDirectoryGrid
      brandSlug={`${make}/${model}`}
      brandName={`${brand.name} ${modelInfo.name}`}
      cities={citiesLive}
    />
  )}

  {citiesOnboarding.length > 0 && (
    <section style="padding:0 16px 32px">
      <h2 class="sr-only">{`${brand.name} ${modelInfo.name} — cities where dealers are onboarding`}</h2>
      {citiesLive.length === 0 && (
        <div class="card" style="padding:20px;margin-bottom:12px;text-align:left">
          <h3 class="t-h-m" style="font-size:17px">New inventory is arriving</h3>
          <p class="t-caption" style="margin-top:8px">Local dealers are onboarding — live listings appear here first.</p>
          <a href="/dealer/signup/" class="t-caption" style="display:inline-block;margin-top:12px">List your inventory →</a>
        </div>
      )}
      <div style="display:grid;grid-template-columns:repeat(2, 1fr);gap:12px">
        {citiesOnboarding.map((c) => (
          <a
            href={`/${c.slug}/${make}/${model}/`}
            class="card"
            style="display:flex;flex-direction:column;justify-content:space-between;padding:20px;min-height:96px;text-align:left"
          >
            <h3 class="t-h-m" style="font-size:17px">{c.name}</h3>
            <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-top:auto;gap:8px">
              <span class="t-caption" style="font-size:10px">Dealers onboarding</span>
              <span class="t-caption t-mono" style="font-size:10px">{c.province}</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <AboutBrandSection title={aboutTitle} paragraphs={aboutParagraphs} />

  <FaqSection
    items={modelFaqs}
    heading={`Common questions about the ${brand.name} ${modelInfo.name}`}
  />
</BaseLayout>
