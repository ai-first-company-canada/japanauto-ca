---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Navbar from '../../../../components/sections/Navbar.astro';
import MenuDrawer from '../../../../components/sections/MenuDrawer.astro';
import CityPickerDialog from '../../../../components/sections/CityPickerDialog.astro';
import Footer from '../../../../components/sections/Footer.astro';
import Breadcrumb from '../../../../components/atoms/Breadcrumb.astro';
import PageHeading from '../../../../components/sections/PageHeading.astro';
import FilterPillBar from '../../../../components/sections/FilterPillBar.astro';
import CatalogList from '../../../../components/sections/CatalogList.astro';
import CatalogPagination from '../../../../components/sections/CatalogPagination.astro';
import ModelCrossLinks from '../../../../components/sections/ModelCrossLinks.astro';
import FaqSection from '../../../../components/sections/FaqSection.astro';
import YearFilterDialog from '../../../../components/sections/YearFilterDialog.astro';
import SortFilterDialog from '../../../../components/sections/SortFilterDialog.astro';
import { BRAND_CONTENT, TIER_1_CITIES } from '../../../../data/brand-content';
import { MODELS_BY_BRAND, getModelsForCity } from '../../../../data/models-stubs';
import { getCatalogForModelCity } from '../../../../data/catalog-stubs';

export function getStaticPaths() {
  const paths: Array<{ params: { make: string; model: string; city: string } }> = [];
  for (const make of Object.keys(MODELS_BY_BRAND)) {
    for (const model of MODELS_BY_BRAND[make]!) {
      for (const city of TIER_1_CITIES) {
        paths.push({ params: { make, model: model.slug, city: city.slug } });
      }
    }
  }
  return paths;
}

const { make, model, city } = Astro.params;
const brand = BRAND_CONTENT[make!]!;
const cityInfo = TIER_1_CITIES.find((c) => c.slug === city)!;
const modelInfo = MODELS_BY_BRAND[make!]!.find((m) => m.slug === model)!;
const catalog = getCatalogForModelCity(make!, model!, modelInfo.name, city!);
const cityShort = `${cityInfo.name}, ${cityInfo.province}`;

const otherModels = getModelsForCity(make!, city!);

const modelFaqs = [
  {
    q: `Is the ${brand.name} ${modelInfo.name} reliable?`,
    a: `${brand.name} models including the ${modelInfo.name} consistently rank in the top tier for long-term reliability across Canadian conditions.`,
  },
  {
    q: `What years of ${brand.name} ${modelInfo.name} are available?`,
    a: `Used ${brand.name} ${modelInfo.name} listings on japanauto.ca cover model years from 2016 to current — the rolling 10-year window for used inventory.`,
  },
  {
    q: `Does the ${brand.name} ${modelInfo.name} have AWD?`,
    a: `AWD availability depends on year and trim. Most ${brand.name} ${modelInfo.name} listings show drivetrain in the spec line. Filter by drive on the listing detail page.`,
  },
  {
    q: `What's the typical price range for a used ${brand.name} ${modelInfo.name}?`,
    a: `Pricing depends on year, mileage, and trim. As a rule, expect roughly 10-15% depreciation per year on top trims, more on base trims.`,
  },
];

const title = `Used ${brand.name} ${modelInfo.name} in ${cityInfo.name}, ${cityInfo.province} — japanauto.ca`;
const description = `${catalog.totalCount} used ${brand.name} ${modelInfo.name} listings in ${cityInfo.name}. AMVIC-verified dealers, VIN-checked vehicles, prices in CA$.`;
const canonical = `https://japanauto.ca/used-cars/${make}/${model}/${city}/`;

const allListings = [...catalog.boosted, ...catalog.organic];
const schemaLD = [
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://japanauto.ca/' },
      { '@type': 'ListItem', position: 2, name: brand.name, item: `https://japanauto.ca/used-cars/${make}/` },
      { '@type': 'ListItem', position: 3, name: modelInfo.name, item: `https://japanauto.ca/used-cars/${make}/${model}/` },
      { '@type': 'ListItem', position: 4, name: cityInfo.name, item: canonical },
    ],
  },
  {
    '@type': 'ItemList',
    name: `Used ${brand.name} ${modelInfo.name} in ${cityInfo.name}`,
    numberOfItems: catalog.totalCount,
    itemListElement: allListings.map((l, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'Vehicle',
        name: `${l.year} ${l.make} ${l.model} ${l.trim}`,
        vehicleModelDate: String(l.year),
        mileageFromOdometer: { '@type': 'QuantitativeValue', value: l.km, unitCode: 'KMT' },
        vehicleTransmission: l.transmission,
        driveWheelConfiguration: l.drive,
        url: `https://japanauto.ca/used-cars/listing/${l.slug}/`,
        offers: {
          '@type': 'Offer',
          price: l.price,
          priceCurrency: 'CAD',
          availability: 'https://schema.org/InStock',
          seller: { '@type': 'AutoDealer', name: l.dealer },
        },
      },
    })),
  },
  {
    '@type': 'Place',
    name: cityInfo.name,
    address: {
      '@type': 'PostalAddress',
      addressLocality: cityInfo.name,
      addressRegion: cityInfo.province,
      addressCountry: 'CA',
    },
  },
  ...(catalog.featured ? [{
    '@type': 'Offer',
    category: 'NewVehicle',
    name: `New ${catalog.featured.year} ${catalog.featured.make} ${catalog.featured.model}`,
    price: catalog.featured.msrp,
    priceCurrency: 'CAD',
    seller: { '@type': 'AutoDealer', name: catalog.featured.dealer },
  }] : []),
  {
    '@type': 'FAQPage',
    mainEntity: modelFaqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
];

const subtitleHtml = `<span class="num">${catalog.totalCount}</span> listings from <span class="num">${catalog.dealerCount}</span> dealers · Updated today`;
const visibleCount = catalog.boosted.length + catalog.organic.length;
---
<BaseLayout
  {title}
  {description}
  {canonical}
  {schemaLD}
  geoFallbackCity={city!}
>
  <Navbar slot="navbar" cityShort={cityShort} />
  <MenuDrawer slot="menu-drawer" cityShort={cityShort} cityName={cityInfo.name} />
  <CityPickerDialog slot="city-picker" />
  <YearFilterDialog slot="filter-dialogs" />
  <SortFilterDialog slot="filter-dialogs" />
  <Footer slot="footer" />

  <h1 class="sr-only">{`Used ${brand.name} ${modelInfo.name} in ${cityInfo.name}, ${cityInfo.province}`}</h1>

  <Breadcrumb items={[
    { label: 'Home', href: '/' },
    { label: brand.name, href: `/used-cars/${make}/` },
    { label: modelInfo.name, href: `/used-cars/${make}/${model}/` },
    { label: cityInfo.name },
  ]} />

  <PageHeading
    title={`Used ${brand.name} ${modelInfo.name} in ${cityShort}`}
    subtitle={subtitleHtml}
  />

  <FilterPillBar />

  <p
    id="catalog-counter"
    class="t-body-s ink-muted"
    style="padding:12px 16px 0;font-size:12px"
  >
    Showing <span class="num">{visibleCount}</span> of <span class="num">{catalog.totalCount}</span> listings
  </p>

  <CatalogList
    featured={catalog.featured}
    boosted={catalog.boosted}
    organic={catalog.organic}
    citySlug={city!}
  />

  <CatalogPagination initialShown={10} />

  <ModelCrossLinks
    brandSlug={make!}
    brandName={brand.name}
    citySlug={city!}
    cityName={cityInfo.name}
    currentModelSlug={model!}
    crossLinks={otherModels}
  />

  <FaqSection
    items={modelFaqs}
    heading={`Common questions about ${brand.name} ${modelInfo.name}`}
  />

  <script is:inline>
    /* Phase 2c2b: replace catalog-grid stubs with real D1 listings if any
       exist for this (make, model, city). Falls back to stubs when the API
       returns 404 (no model match yet) or empty boosted+organic. */
    (function () {
      function escapeHTML(s) {
        return String(s == null ? '' : s)
          .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
      }
      function fmt(n) { return Number(n).toLocaleString('en-US'); }
      function relTime(ts) {
        var ageSec = Math.floor(Date.now() / 1000) - ts;
        if (ageSec < 86400) return 'Listed today';
        var d = Math.floor(ageSec / 86400);
        if (d === 1) return 'Listed 1 day ago';
        if (d < 7) return 'Listed ' + d + ' days ago';
        if (d < 14) return 'Listed 1 week ago';
        if (d < 30) return 'Listed ' + Math.floor(d / 7) + ' weeks ago';
        return 'Listed ' + Math.floor(d / 30) + ' months ago';
      }
      function pretty(slug) {
        return String(slug).split('-').map(function (w) {
          return w.charAt(0).toUpperCase() + w.slice(1);
        }).join(' ');
      }
      function cardHTML(l) {
        var price = Math.round(l.price / 100);
        var trim = l.trim ? ' ' + escapeHTML(l.trim) : '';
        var img = l.primary_image_url
          ? '<img src="' + escapeHTML(l.primary_image_url) + '" alt="" loading="lazy" style="width:100%;height:100%;object-fit:cover" />'
          : '';
        var tier = l.is_boosted ? 'boosted' : 'organic';
        return ''
          + '<a href="/used-cars/listing/' + escapeHTML(l.slug) + '/" class="card" '
          + 'data-year="' + l.year + '" data-price="' + price + '" data-mileage="' + l.mileage + '" '
          + 'data-tier="' + tier + '" '
          + 'style="overflow:hidden;display:flex;flex-direction:column">'
          + '<div class="thumb" style="background:var(--color-bg-muted)">' + img + '</div>'
          + '<div style="padding:14px;display:flex;flex-direction:column;gap:6px">'
          + (l.is_boosted
              ? '<span class="badge" style="align-self:flex-start;margin-bottom:2px"><span class="dot"></span>Boosted</span>'
              : '')
          + '<h3 class="t-h-s" style="font-size:14px;line-height:20px;font-weight:600">'
          +   l.year + ' ' + escapeHTML(pretty(l.make_slug)) + ' ' + escapeHTML(pretty(l.model_slug)) + trim
          + '</h3>'
          + '<p class="t-body-s ink-muted" style="font-size:12px;line-height:16px">'
          +   fmt(l.mileage) + ' km · ' + escapeHTML(l.transmission || 'Auto') + ' · ' + escapeHTML(l.drivetrain || 'AWD')
          + '</p>'
          + '<div style="display:flex;align-items:baseline;gap:8px;margin-top:2px">'
          +   '<span class="num" style="font-size:18px;font-weight:600;color:#0A0A0A;letter-spacing:-0.01em">CA$' + fmt(price) + '</span>'
          + '</div>'
          + '<p class="t-body-s ink-muted" style="font-size:11px;line-height:14px;margin-top:4px;color:var(--color-ink-subtle)">'
          +   relTime(l.created_at) + ' · ' + escapeHTML(l.dealer_name)
          + '</p>'
          + '</div>'
          + '</a>';
      }

      var path = window.location.pathname;
      var m = path.match(/\/used-cars\/([^/]+)\/([^/]+)\/([^/]+)\/?$/);
      if (m) {
        var make = m[1], model = m[2], city = m[3];
        var params = new URLSearchParams({ make: make, model: model, city: city, per_page: '20' });
        fetch('/api/listings?' + params.toString(), { headers: { 'accept': 'application/json' } })
          .then(function (r) { return r.ok ? r.json() : null; })
          .then(function (data) {
            if (!data) return;
            var all = (data.boosted || []).concat(data.organic || []);
            if (all.length === 0) return;
            var grid = document.getElementById('catalog-grid');
            if (!grid) return;
            grid.innerHTML = all.map(cardHTML).join('');
            var counter = document.getElementById('catalog-counter');
            var total = (data.pagination && data.pagination.total) || all.length;
            if (counter) {
              counter.innerHTML = 'Showing <span class="num">' + all.length
                + '</span> of <span class="num">' + total + '</span> listings';
            }
            if (typeof window.applyCatalogFilters === 'function') window.applyCatalogFilters();
          })
          .catch(function () { /* keep stubs */ });
      }
    })();

    (function () {
      window.applyCatalogFilters = function () {
        var params = new URLSearchParams(window.location.search);
        var rawYear = params.get('year') || '';
        var yearFilter = rawYear.split(',').filter(Boolean);
        var sortKey = params.get('sort') || 'newest';
        var grid = document.getElementById('catalog-grid');
        if (!grid) return;
        var cards = Array.prototype.slice.call(grid.querySelectorAll('[data-year]'));
        var visible = 0;
        for (var i = 0; i < cards.length; i++) {
          var card = cards[i];
          var year = card.getAttribute('data-year');
          var matchYear = yearFilter.length === 0 || yearFilter.indexOf(year) !== -1;
          if (matchYear) {
            card.style.display = '';
            visible++;
          } else {
            card.style.display = 'none';
          }
        }
        var visibleCards = cards.filter(function (c) { return c.style.display !== 'none'; });
        visibleCards.sort(function (a, b) {
          var aTier = a.getAttribute('data-tier') === 'boosted' ? 0 : 1;
          var bTier = b.getAttribute('data-tier') === 'boosted' ? 0 : 1;
          if (aTier !== bTier) return aTier - bTier;
          if (sortKey === 'price-asc') {
            return Number(a.getAttribute('data-price')) - Number(b.getAttribute('data-price'));
          }
          if (sortKey === 'price-desc') {
            return Number(b.getAttribute('data-price')) - Number(a.getAttribute('data-price'));
          }
          if (sortKey === 'km-asc') {
            return Number(a.getAttribute('data-mileage')) - Number(b.getAttribute('data-mileage'));
          }
          if (sortKey === 'year-desc') {
            return Number(b.getAttribute('data-year')) - Number(a.getAttribute('data-year'));
          }
          return 0;
        });
        for (var j = 0; j < visibleCards.length; j++) {
          grid.appendChild(visibleCards[j]);
        }
        var counter = document.getElementById('catalog-counter');
        if (counter) {
          counter.innerHTML = 'Showing <span class="num">' + visible + '</span> of <span class="num">' + cards.length + '</span> listings';
        }
        document.dispatchEvent(new CustomEvent('catalog-filtered'));
      };

      function init() {
        if (window.location.search) {
          window.applyCatalogFilters();
        } else {
          document.dispatchEvent(new CustomEvent('catalog-filtered'));
        }
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    })();
  </script>
</BaseLayout>
