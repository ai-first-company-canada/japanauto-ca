---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Navbar from '../../../components/sections/Navbar.astro';
import MenuDrawer from '../../../components/sections/MenuDrawer.astro';
import CityPickerDialog from '../../../components/sections/CityPickerDialog.astro';
import Footer from '../../../components/sections/Footer.astro';
import Breadcrumb from '../../../components/atoms/Breadcrumb.astro';
import ListingPhotoGallery from '../../../components/sections/ListingPhotoGallery.astro';
import ListingTitleBlock from '../../../components/sections/ListingTitleBlock.astro';
import PriceBlock from '../../../components/sections/PriceBlock.astro';
import KeySpecsGrid from '../../../components/sections/KeySpecsGrid.astro';
import DescriptionSection from '../../../components/sections/DescriptionSection.astro';
import DealerCard from '../../../components/sections/DealerCard.astro';
import AmvicVerifyBlock from '../../../components/sections/AmvicVerifyBlock.astro';
import LegalDisclaimer from '../../../components/sections/LegalDisclaimer.astro';
import ListingFeed from '../../../components/sections/ListingFeed.astro';
import CrossCmaListings from '../../../components/sections/CrossCmaListings.astro';
import FaqSection from '../../../components/sections/FaqSection.astro';
import StickyContactBar from '../../../components/sections/StickyContactBar.astro';

import { TIER_1_CITIES } from '../../../data/brand-content';
import { MODELS_BY_BRAND } from '../../../data/models-stubs';
import {
  getCatalogForModelCity,
  type CatalogListing,
  type ListingTone,
} from '../../../data/catalog-stubs';
import { getDealerByName, type ExtendedListing } from '../../../data/dealer-stubs';
import type { ListingPhotoFraming } from '../../../components/atoms/ListingPhoto.astro';

interface PageProps {
  listing: CatalogListing;
  make: string;
  modelSlug: string;
  citySlug: string;
  cityName: string;
  cityProvince: string;
}

export function getStaticPaths() {
  const paths: Array<{ params: { slug: string }; props: PageProps }> = [];
  for (const make of Object.keys(MODELS_BY_BRAND)) {
    const models = MODELS_BY_BRAND[make]!;
    for (const modelStub of models) {
      for (const city of TIER_1_CITIES) {
        const catalog = getCatalogForModelCity(make, modelStub.slug, modelStub.name, city.slug);
        for (const listing of [...catalog.boosted, ...catalog.organic]) {
          paths.push({
            params: { slug: listing.slug },
            props: {
              listing,
              make,
              modelSlug: modelStub.slug,
              citySlug: city.slug,
              cityProvince: city.province,
              cityName: city.name,
            },
          });
        }
      }
    }
  }
  return paths;
}

const { listing, make, modelSlug, citySlug, cityName, cityProvince } =
  Astro.props as PageProps;
const dealer = getDealerByName(listing.dealer);

const FRAMINGS: ListingPhotoFraming[] = [
  'three-quarter',
  'side',
  'rear-three-quarter',
  'front-low',
  'interior',
  'dash',
  'wheel-detail',
  'engine-bay',
];

const photos = FRAMINGS.map((framing) => ({ tone: listing.tone as ListingTone, framing }));

const bodyType =
  listing.variant === 'sedan'
    ? 'Sedan'
    : listing.variant === 'suv'
      ? 'SUV'
      : listing.variant === 'hatch'
        ? 'Hatchback'
        : 'Wagon';

const slugDigits = listing.slug.replace(/\D/g, '');
const vinSeed = slugDigits.length > 0 ? parseInt(slugDigits.slice(-6), 10) || 0 : 0;
const vinSuffix = (vinSeed % 1000000).toString().padStart(6, '0');

const extendedListing: ExtendedListing = {
  ...listing,
  drivetrain: listing.drive,
  fuel: 'Gasoline',
  bodyType,
  doors: listing.variant === 'wagon' ? 5 : 4,
  seats: listing.variant === 'suv' ? 7 : 5,
  engine: '2.5L',
  exteriorColor: listing.tone.charAt(0).toUpperCase() + listing.tone.slice(1) + ' Metallic',
  interiorColor: 'Black',
  vin: '1HGBH41JXMN' + vinSuffix,
  vinVerified: true,
  condition: 'Used — Good',
  description: [
    `Single owner. All maintenance records available. Recent service includes inspection at ${dealer.name}. No accidents reported. Clean title.`,
    `Comes with two key fobs and original window sticker. ${listing.km < 70000 ? 'Low mileage example for the year.' : 'Well-maintained over its lifespan.'}`,
  ],
};

const listingFaqs = [
  {
    q: `How reliable is a ${listing.make} ${listing.model}?`,
    a: `${listing.make} models including the ${listing.model} consistently rank top-tier for long-term reliability across Canadian conditions.`,
  },
  {
    q: `What's the average mileage for a ${listing.year} ${listing.model}?`,
    a: `Around ${(Math.round(listing.km / 1000) * 1000).toLocaleString('en-US')} km is typical for ${listing.year} examples. Lease returns cluster between 30,000 and 70,000 km.`,
  },
  {
    q: `Is the ${listing.trim} trim worth buying used?`,
    a: `The ${listing.trim} trim offers a strong balance of features and value. Specific equipment varies by year — confirm with the dealer.`,
  },
  {
    q: 'Should I get a pre-purchase inspection?',
    a: `Yes, on any used vehicle priced above CA$10,000. Expect to pay CA$150–CA$250 in ${cityName} at an independent shop.`,
  },
];

const sameCityCatalog = getCatalogForModelCity(make, modelSlug, listing.model, citySlug);
const related = [...sameCityCatalog.boosted, ...sameCityCatalog.organic]
  .filter((l) => l.slug !== listing.slug)
  .slice(0, 4);

const otherCities = TIER_1_CITIES
  .filter((c) => c.slug !== citySlug)
  .map((c) => {
    const cityCatalog = getCatalogForModelCity(make, modelSlug, listing.model, c.slug);
    return { slug: c.slug, name: c.name, count: cityCatalog.totalCount };
  });

const sold = false;

const driveConfig =
  listing.drive === 'AWD'
    ? 'https://schema.org/AllWheelDriveConfiguration'
    : listing.drive === 'FWD'
      ? 'https://schema.org/FrontWheelDriveConfiguration'
      : 'https://schema.org/RearWheelDriveConfiguration';

const title = `${listing.year} ${listing.make} ${listing.model} ${listing.trim} — CA$${listing.price.toLocaleString('en-US')} — ${cityName}, ${cityProvince}`;
const description = `${listing.year} ${listing.make} ${listing.model} ${listing.trim} for sale in ${cityName}, ${cityProvince}. ${listing.km.toLocaleString('en-US')} km, ${listing.transmission}, ${listing.drive}. CA$${listing.price.toLocaleString('en-US')} from ${dealer.name}.`;
const canonical = `https://japanauto.ca/used-cars/listing/${listing.slug}/`;

const schemaLD = [
  {
    '@type': 'Vehicle',
    name: `${listing.year} ${listing.make} ${listing.model} ${listing.trim}`,
    vehicleModelDate: String(listing.year),
    vehicleIdentificationNumber: extendedListing.vin,
    modelDate: String(listing.year),
    manufacturer: listing.make,
    model: listing.model,
    vehicleConfiguration: listing.trim,
    mileageFromOdometer: {
      '@type': 'QuantitativeValue',
      value: listing.km,
      unitCode: 'KMT',
    },
    vehicleTransmission: listing.transmission,
    driveWheelConfiguration: driveConfig,
    fuelType: 'Gasoline',
    bodyType: extendedListing.bodyType,
    color: extendedListing.exteriorColor,
    numberOfDoors: extendedListing.doors,
    vehicleSeatingCapacity: extendedListing.seats,
    offers: {
      '@type': 'Offer',
      price: listing.price,
      priceCurrency: 'CAD',
      availability: sold ? 'https://schema.org/SoldOut' : 'https://schema.org/InStock',
      seller: {
        '@type': 'AutoDealer',
        name: dealer.name,
        telephone: dealer.phoneTel,
        email: dealer.email,
        url: dealer.webHref,
        address: {
          '@type': 'PostalAddress',
          streetAddress: dealer.address.split(',')[0],
          addressLocality: dealer.city,
          addressRegion: dealer.province,
          addressCountry: 'CA',
        },
        areaServed: dealer.city,
      },
    },
  },
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://japanauto.ca/' },
      { '@type': 'ListItem', position: 2, name: listing.make, item: `https://japanauto.ca/used-cars/${make}/` },
      { '@type': 'ListItem', position: 3, name: listing.model, item: `https://japanauto.ca/used-cars/${make}/${modelSlug}/` },
      { '@type': 'ListItem', position: 4, name: cityName, item: `https://japanauto.ca/used-cars/${make}/${modelSlug}/${citySlug}/` },
      { '@type': 'ListItem', position: 5, name: `${listing.year} ${listing.trim}`, item: canonical },
    ],
  },
  {
    '@type': 'FAQPage',
    mainEntity: listingFaqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
];

const stickyPhoto = photos[0]!;
---

<BaseLayout {title} {description} {canonical} {schemaLD}>
  <Navbar slot="navbar" />
  <MenuDrawer slot="menu-drawer" />
  <CityPickerDialog slot="city-picker" />
  <Footer slot="footer" />

  {sold && (
    <div style="background:var(--color-ink-strong);color:#fff;height:48px;display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:600;letter-spacing:0.08em">
      SOLD
    </div>
  )}

  <Breadcrumb
    items={[
      { label: 'Home', href: '/' },
      { label: listing.make, href: `/used-cars/${make}/` },
      { label: listing.model, href: `/used-cars/${make}/${modelSlug}/` },
      { label: cityName, href: `/used-cars/${make}/${modelSlug}/${citySlug}/` },
      { label: `${listing.year} ${listing.trim}` },
    ]}
  />

  <ListingPhotoGallery
    photos={photos}
    title={`${listing.year} ${listing.make} ${listing.model} ${listing.trim}`}
  />

  <ListingTitleBlock listing={listing} city={cityName} province={cityProvince} sold={sold} />
  <PriceBlock
    price={listing.price}
    negotiable={true}
    reduced={listing.reduced}
    sold={sold}
  />

  <KeySpecsGrid listing={extendedListing} />
  <DescriptionSection paragraphs={extendedListing.description} />

  <DealerCard dealer={dealer} sold={sold} />

  {dealer.province === 'AB' && dealer.type === 'dealer' && dealer.amvic && (
    <AmvicVerifyBlock dealer={dealer} />
  )}

  <LegalDisclaimer />

  {related.length > 0 && (
    <ListingFeed
      heading={
        sold
          ? `Other available ${listing.year} ${listing.make} ${listing.model} in ${cityName}`
          : `More ${listing.year} ${listing.make} ${listing.model} in ${cityName}`
      }
      listings={related}
    />
  )}

  <CrossCmaListings
    make={make}
    model={modelSlug}
    currentCitySlug={citySlug}
    cities={otherCities}
    makeName={listing.make}
    modelName={listing.model}
  />

  <FaqSection items={listingFaqs} heading={`Common questions about ${listing.make} ${listing.model}`} />

  {!sold && (
    <StickyContactBar
      slot="sticky-bar"
      listing={listing}
      dealer={dealer}
      photo={stickyPhoto}
    />
  )}
</BaseLayout>
