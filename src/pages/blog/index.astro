---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/sections/Navbar.astro';
import MenuDrawer from '../../components/sections/MenuDrawer.astro';
import CityPickerDialog from '../../components/sections/CityPickerDialog.astro';
import Footer from '../../components/sections/Footer.astro';
import Breadcrumb from '../../components/atoms/Breadcrumb.astro';
import {
  breadcrumbList, itemList,
  AUTHOR_BIOS, CATEGORY_LABELS, CATEGORY_ORDER, formatIsoDate,
} from '../../lib/schema-graph';

const url = Astro.url.toString();
const posts = await getCollection('blog');

const byCategory = new Map<string, typeof posts>();
for (const c of CATEGORY_ORDER) byCategory.set(c, []);
for (const p of posts) {
  const arr = byCategory.get(p.data.category) ?? [];
  arr.push(p);
  byCategory.set(p.data.category, arr);
}
// Sort each category by pub_date desc, fall back to title for stability.
for (const [k, arr] of byCategory) {
  arr.sort((a, b) => {
    const da = a.data.pub_date ?? '';
    const db = b.data.pub_date ?? '';
    if (da !== db) return db.localeCompare(da);
    return a.data.title.localeCompare(b.data.title);
  });
}

const schemaLD = [
  {
    '@type': 'Blog',
    '@id': `${url}#blog`,
    name: 'japanauto.ca Blog',
    description: 'Buying guides, model deep-dives, regulatory explainers, and parts knowledge for Japanese cars in Canada.',
    url,
    inLanguage: 'en-CA',
    publisher: { '@id': 'https://japanauto.ca/#organization' },
  },
  itemList(
    posts.map((p) => ({
      name: p.data.h1,
      url: `https://japanauto.ca/blog/${p.data.slug}/`,
    })),
    'Latest articles',
  ),
  breadcrumbList(
    [
      { label: 'Home', href: '/' },
      { label: 'Blog' },
    ],
    url,
  ),
].filter(Boolean);
---
<BaseLayout
  title="japanauto.ca Blog — Buying guides, model deep-dives, regulations"
  description="Buying guides, regulatory explainers (AMVIC, OMVIC, UVIP, GST/HST), Japanese model deep-dives, and parts how-tos for Canadian buyers."
  canonical={url}
  schemaLD={schemaLD}
>
  <Navbar slot="navbar" />
  <MenuDrawer slot="menu-drawer" />
  <CityPickerDialog slot="city-picker" />
  <Footer slot="footer" />

  <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Blog' }]} />

  <section class="section" style="padding-top:8px">
    <h1 class="t-display-l" style="font-size:32px;line-height:40px;margin-bottom:8px">
      japanauto.ca Blog
    </h1>
    <p class="t-body-m ink-muted" style="font-size:14px;line-height:22px;max-width:680px">
      Practical, Canada-specific guides for buying, owning, and parting out used Japanese vehicles. Independent — not paid by manufacturers.
    </p>
  </section>

  {CATEGORY_ORDER.map((cat) => {
    const items = byCategory.get(cat) ?? [];
    if (!items.length) return null;
    return (
      <section class="section">
        <header style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:12px">
          <h2 class="t-h-l" style="font-size:20px">{CATEGORY_LABELS[cat]}</h2>
          <span class="t-caption" style="font-size:10px;color:var(--color-ink-muted)">{items.length} article{items.length === 1 ? '' : 's'}</span>
        </header>
        <div style="display:flex;flex-direction:column;gap:12px">
          {items.map((p) => {
            const author = AUTHOR_BIOS[p.data.author];
            const tldr = (p.data.tldr_draft ?? '').slice(0, 140).replace(/\s+\S*$/, '') + '…';
            return (
              <a
                href={`/blog/${p.data.slug}/`}
                class="card"
                style="display:flex;flex-direction:column;gap:8px;padding:16px;text-decoration:none"
              >
                <span class="t-caption" style="font-size:10px;color:var(--color-ink-muted)">{CATEGORY_LABELS[cat]}</span>
                <h3 class="t-h-m" style="font-size:16px;line-height:22px;color:var(--color-ink-strong)">{p.data.h1}</h3>
                <p class="t-body-s ink-muted" style="font-size:13px;line-height:19px">{tldr}</p>
                <div class="t-body-s ink-subtle" style="font-size:11px;line-height:16px">
                  {author.name}{p.data.pub_date ? ` · ${formatIsoDate(p.data.pub_date)}` : ''}
                </div>
              </a>
            );
          })}
        </div>
      </section>
    );
  })}
</BaseLayout>
