---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/sections/Navbar.astro';
import MenuDrawer from '../components/sections/MenuDrawer.astro';
import CityPickerDialog from '../components/sections/CityPickerDialog.astro';
import Footer from '../components/sections/Footer.astro';
import BrandGrid from '../components/atoms/BrandGrid.astro';
import OtherCitiesCollapse from '../components/atoms/OtherCitiesCollapse.astro';
import Icon from '../components/atoms/Icon.astro';
import ListingFeed, { type FeedListing } from '../components/sections/ListingFeed.astro';
import PopularModels, { type PopularModel } from '../components/sections/PopularModels.astro';
import TrustStrip from '../components/sections/TrustStrip.astro';
import PartsEntryPoint from '../components/sections/PartsEntryPoint.astro';
import BlogExcerpt, { type BlogArticle } from '../components/sections/BlogExcerpt.astro';
import GlossaryHighlights, { type GlossaryTerm } from '../components/sections/GlossaryHighlights.astro';
import FaqSection, { type FaqItem } from '../components/sections/FaqSection.astro';
import SellCta from '../components/sections/SellCta.astro';
import { TIER_1_CITIES } from '../data/brand-content';
import { faqPage, itemList } from '../lib/schema-graph';

// National brand totals = Toronto baseline × (sum of city counts / 1284).
// CITY_FACTOR_SUM is the cumulative scaling factor across the 6 Tier-1 CMAs.
const CITY_FACTOR_SUM = TIER_1_CITIES.reduce((s, c) => s + c.count / 1284, 0);

const BRANDS = [
  { slug: 'toyota',     name: 'Toyota',     baseCount: 78 },
  { slug: 'honda',      name: 'Honda',      baseCount: 64 },
  { slug: 'nissan',     name: 'Nissan',     baseCount: 52 },
  { slug: 'mazda',      name: 'Mazda',      baseCount: 41 },
  { slug: 'subaru',     name: 'Subaru',     baseCount: 36 },
  { slug: 'lexus',      name: 'Lexus',      baseCount: 28 },
  { slug: 'acura',      name: 'Acura',      baseCount: 22 },
  { slug: 'infiniti',   name: 'Infiniti',   baseCount: 17 },
  { slug: 'mitsubishi', name: 'Mitsubishi', baseCount: 14 },
].map((b) => ({ slug: b.slug, name: b.name, count: Math.round(b.baseCount * CITY_FACTOR_SUM) }));

const NATIONAL_TOTAL = BRANDS.reduce((s, b) => s + b.count, 0);
const NATIONAL_DEALERS = Math.round(40 * CITY_FACTOR_SUM);

const DEALER_NAMES = [
  'Maple Auto Group', 'North Star Motors', 'Cypress Imports', 'Eastside Pre-Owned',
  'Summit Japanese Auto', 'Westview Cars', 'Granite Motors', 'Riverbend Auto',
];

const LISTINGS_SEED: Array<Omit<FeedListing, 'dealer'>> = [
  { year: 2021, make: 'Toyota', model: 'Camry',   trim: 'LE',       km: 58400,  drive: 'AWD', transmission: 'CVT',  price: 24900, listed: 'Listed today',       variant: 'sedan', tone: 'pearl',    badge: 'New today', slug: '2021-toyota-camry-le-toronto-ab1234' },
  { year: 2019, make: 'Honda',  model: 'CR-V',    trim: 'EX',       km: 71200,  drive: 'AWD', transmission: 'CVT',  price: 26450, listed: 'Listed 2 days ago',  variant: 'suv',   tone: 'midnight', badge: 'New today', slug: '2019-honda-crv-ex-toronto-cd5678' },
  { year: 2020, make: 'Mazda',  model: 'CX-5',    trim: 'GS',       km: 64800,  drive: 'AWD', transmission: 'Auto', price: 23900, listed: 'Listed 3 days ago',  variant: 'suv',   tone: 'crimson',  slug: '2020-mazda-cx5-gs-toronto-ef9012' },
  { year: 2018, make: 'Subaru', model: 'Outback', trim: '2.5i',     km: 92500,  drive: 'AWD', transmission: 'CVT',  price: 19800, listed: 'Listed 4 days ago',  variant: 'wagon', tone: 'forest',   reduced: 1500, slug: '2018-subaru-outback-25i-toronto-gh3456' },
  { year: 2022, make: 'Lexus',  model: 'NX 350',  trim: 'F-Sport',  km: 38900,  drive: 'AWD', transmission: 'Auto', price: 48900, listed: 'Listed 5 days ago',  variant: 'suv',   tone: 'graphite', slug: '2022-lexus-nx350-fsport-toronto-ij7890' },
  { year: 2017, make: 'Honda',  model: 'Civic',   trim: 'LX',       km: 108200, drive: 'FWD', transmission: 'CVT',  price: 14900, listed: 'Listed 6 days ago',  variant: 'sedan', tone: 'silver',   slug: '2017-honda-civic-lx-toronto-kl2345' },
  { year: 2020, make: 'Toyota', model: 'RAV4',    trim: 'XLE',      km: 67400,  drive: 'AWD', transmission: 'Auto', price: 32400, listed: 'Listed 1 week ago',  variant: 'suv',   tone: 'sand',     slug: '2020-toyota-rav4-xle-toronto-mn6789' },
  { year: 2019, make: 'Nissan', model: 'Rogue',   trim: 'SV',       km: 81200,  drive: 'AWD', transmission: 'CVT',  price: 21300, listed: 'Listed 1 week ago',  variant: 'suv',   tone: 'pearl',    slug: '2019-nissan-rogue-sv-toronto-op0123' },
];

const LISTINGS: FeedListing[] = LISTINGS_SEED.map((l, i) => ({
  ...l,
  dealer: DEALER_NAMES[i % DEALER_NAMES.length]!,
}));

const POPULAR_MODELS: PopularModel[] = [
  { make: 'Toyota', model: 'Camry',   body: 'Sedan', years: '2018–2024', from: 17900, variant: 'sedan', tone: 'pearl',    href: '/used-cars/toyota/camry/' },
  { make: 'Honda',  model: 'Civic',   body: 'Sedan', years: '2017–2024', from: 14400, variant: 'sedan', tone: 'silver',   href: '/used-cars/honda/civic/' },
  { make: 'Toyota', model: 'RAV4',    body: 'SUV',   years: '2018–2024', from: 21900, variant: 'suv',   tone: 'graphite', href: '/used-cars/toyota/rav4/' },
  { make: 'Honda',  model: 'CR-V',    body: 'SUV',   years: '2018–2024', from: 19800, variant: 'suv',   tone: 'midnight', href: '/used-cars/honda/cr-v/' },
  { make: 'Mazda',  model: 'Mazda3',  body: 'Hatch', years: '2017–2024', from: 13900, variant: 'hatch', tone: 'crimson',  href: '/used-cars/mazda/mazda3/' },
  { make: 'Subaru', model: 'Outback', body: 'Wagon', years: '2017–2024', from: 16400, variant: 'wagon', tone: 'forest',   href: '/used-cars/subaru/outback/' },
];

const OTHER_CITIES = [
  { slug: 'toronto',   name: 'Toronto',   province: 'ON', count: 1284 },
  { slug: 'montreal',  name: 'Montreal',  province: 'QC', count: 938 },
  { slug: 'vancouver', name: 'Vancouver', province: 'BC', count: 871 },
  { slug: 'calgary',   name: 'Calgary',   province: 'AB', count: 612 },
  { slug: 'edmonton',  name: 'Edmonton',  province: 'AB', count: 487 },
  { slug: 'ottawa',    name: 'Ottawa',    province: 'ON', count: 412 },
];

const FAQ_ITEMS: FaqItem[] = [
  {
    q: 'Why are Japanese cars popular in Canada?',
    a: 'Japanese-built cars consistently rank among the top for long-term reliability and resale value in Canadian conditions. Brands like Toyota, Honda and Subaru are over-represented in vehicles that pass 250,000 km without major repairs, which matters in a country where winter driving and long highway commutes are common.',
  },
  {
    q: 'Do I need an AMVIC-registered dealer in Alberta?',
    a: "Yes. In Alberta, anyone who sells more than four vehicles a year must be licensed by AMVIC (Alberta Motor Vehicle Industry Council). Buying from a licensed dealer means access to the consumer compensation fund and recourse if something goes wrong. Every Alberta listing on japanauto.ca shows the dealer's AMVIC number.",
  },
  {
    q: "What's the difference between OEM and aftermarket parts?",
    a: "OEM (Original Equipment Manufacturer) parts are made by or for the original carmaker and match factory spec exactly. Aftermarket parts are made by third parties — they're usually cheaper and sometimes better, but quality varies. For safety-critical components like brakes and airbags, most owners stay with OEM.",
  },
  {
    q: 'How do I check a VIN before buying?',
    a: 'Run the 17-digit VIN through CarFax Canada or a similar history service. Check that the VIN on the windshield, doorjamb and registration all match. A VIN history can reveal accident reports, previous registrations across provinces, and any salvage or rebuilt title brands.',
  },
  {
    q: 'What taxes apply when buying a used car in Canada?',
    a: 'Tax depends on the province where you register the vehicle. Most provinces apply GST/HST or PST on top of the purchase price; Alberta has no provincial sales tax on private sales but charges 5% GST through dealers. Always confirm the total before you sign the bill of sale.',
  },
  {
    q: 'Are salvage-title Japanese cars worth it?',
    a: 'Sometimes — but go in with eyes open. A salvage or rebuilt title means the vehicle was once a total loss. Even after repair, resale value and insurability are lower. They can be reasonable for daily drivers if a qualified mechanic inspects the structural repairs first.',
  },
];

const BLOG_ARTICLES: BlogArticle[] = [
  {
    cat: 'Buying guide',
    title: 'How to verify an AMVIC dealer in Alberta',
    excerpt: "A 3-minute walkthrough of the public registry — what the licence number tells you and what it doesn't.",
    read: '5 min read',
    date: '2026-04-22',
    tone: '#1F2530',
    slug: 'how-to-verify-amvic-dealer-alberta',
  },
  {
    cat: 'Maintenance',
    title: 'CVT vs. conventional automatic on a used Camry',
    excerpt: 'Long-term reliability, what to listen for on a test drive, and when to walk away.',
    read: '7 min read',
    date: '2026-04-15',
    tone: '#3A3A3D',
    slug: 'cvt-vs-automatic-used-camry',
  },
  {
    cat: 'Market',
    title: 'JDM imports in Canada: the 15-year rule, explained',
    excerpt: 'A plain-English summary of what you can legally import and what to budget for compliance.',
    read: '6 min read',
    date: '2026-04-08',
    tone: '#2F3D2F',
    slug: 'jdm-imports-canada-15-year-rule',
  },
];

const GLOSSARY_TERMS: GlossaryTerm[] = [
  { term: 'AMVIC', def: "Alberta's dealer licensing body." },
  { term: 'AWD',   def: 'All-wheel drive — power to all four wheels.' },
  { term: 'CVT',   def: 'Continuously variable transmission.' },
  { term: 'OEM',   def: 'Original Equipment Manufacturer parts.' },
  { term: 'JDM',   def: 'Japanese Domestic Market vehicles.' },
  { term: 'VIN',   def: '17-digit vehicle identification number.' },
];

const SITE = 'https://japanauto.ca';

// Page-level structured data, merged into the BaseLayout @graph (Organization +
// WebSite). FAQPage mirrors the visible FaqSection 1:1; two ItemLists expose the
// model and city collections to search crawlers and answer engines. Helpers
// return null when empty, so each is spread in only when present (type-safe).
const homeFaq = faqPage(
  FAQ_ITEMS.map((f) => f.q),
  FAQ_ITEMS.map((f) => f.a),
);
const modelsList = itemList(
  POPULAR_MODELS.map((m) => ({
    name: `${m.make} ${m.model}`,
    url: `${SITE}${m.href ?? `/used-cars/${m.make.toLowerCase()}/${m.model.toLowerCase().replace(/\s+/g, '-')}/`}`,
  })),
  'Popular used Japanese models in Canada',
);
const citiesList = itemList(
  OTHER_CITIES.map((c) => ({
    name: `Used Japanese cars in ${c.name}`,
    url: `${SITE}/${c.slug}/`,
  })),
  'Browse used Japanese cars by Canadian city',
);
const schemaLD = [
  ...(homeFaq ? [homeFaq] : []),
  ...(modelsList ? [modelsList] : []),
  ...(citiesList ? [citiesList] : []),
];

const title = 'Used Japanese cars and parts in Canada — japanauto.ca';
const description = 'Find used Toyota, Honda, Nissan, Mazda, Subaru, Lexus, Acura, Infiniti, Mitsubishi cars from local Canadian dealers. AMVIC-verified, VIN-checked listings.';
---
<BaseLayout {title} {description} canonical="https://japanauto.ca/" {schemaLD}>
  <Navbar slot="navbar" />
  <MenuDrawer slot="menu-drawer" />
  <CityPickerDialog slot="city-picker" />
  <Footer slot="footer" />

  <h1 class="sr-only">Used Japanese cars and parts across Canada — japanauto.ca</h1>

  <section style="padding-block:24px 8px" class="gutter">
    <p class="t-body-l ink-strong" style="max-width:62ch;line-height:1.5">
      <strong>japanauto.ca</strong> is an independent Canadian marketplace for used Japanese cars and
      salvage-yard donor parts, aggregating AMVIC- and OMVIC-verified dealer listings across Toronto,
      Montreal, Vancouver, Calgary, Edmonton and Ottawa.
    </p>
    <p class="t-body-s ink-muted" style="font-size:13px;margin-top:10px">
      <span class="num">{NATIONAL_TOTAL.toLocaleString('en-US')}</span> used Japanese cars
      from <span class="num">{NATIONAL_DEALERS}</span> dealers across {TIER_1_CITIES.length} Canadian cities · Updated today ·
      <a href="/editorial-policy/" style="color:var(--color-ink-default);text-decoration:underline">every regulatory claim is fact-checked by a licensed advisor</a>
    </p>
  </section>

  <section class="section" style="padding-top:8px">
    <BrandGrid brands={BRANDS} />
    <div style="display:flex;justify-content:flex-end;margin-top:16px">
      <a
        class="t-body-s"
        href="/brands/"
        style="display:inline-flex;align-items:center;gap:6px;color:var(--color-ink-default);font-size:14px"
      >
        View all brand pages
        <Icon name="arrowRight" size={14} />
      </a>
    </div>
  </section>

  <ListingFeed
    heading="Latest Japanese cars across Canada"
    listings={LISTINGS}
    ctaText="View all listings"
    ctaHref="/used-cars/"
  />

  <PopularModels heading="Popular Japanese models in" cityName="Canada" models={POPULAR_MODELS} />

  <TrustStrip />

  <section class="section">
    <OtherCitiesCollapse cities={OTHER_CITIES} label="Browse by city" />
  </section>

  <PartsEntryPoint />

  <BlogExcerpt articles={BLOG_ARTICLES} />

  <GlossaryHighlights terms={GLOSSARY_TERMS} />

  <FaqSection items={FAQ_ITEMS} />

  <SellCta />
</BaseLayout>
