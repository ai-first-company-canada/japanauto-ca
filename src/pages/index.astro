---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/sections/Navbar.astro';
import MenuDrawer from '../components/sections/MenuDrawer.astro';
import CityPickerDialog from '../components/sections/CityPickerDialog.astro';
import Footer from '../components/sections/Footer.astro';
import Icon from '../components/atoms/Icon.astro';
import CarSilhouette from '../components/atoms/CarSilhouette.astro';
import ListingFeed from '../components/sections/ListingFeed.astro';
import TrustStrip from '../components/sections/TrustStrip.astro';
import PartsEntryPoint from '../components/sections/PartsEntryPoint.astro';
import BlogExcerpt, { type BlogArticle } from '../components/sections/BlogExcerpt.astro';
import GlossaryHighlights, { type GlossaryTerm } from '../components/sections/GlossaryHighlights.astro';
import FaqSection, { type FaqItem } from '../components/sections/FaqSection.astro';
import SellCta from '../components/sections/SellCta.astro';
import { TIER_1_CITIES } from '../data/brand-content';
import { liveCounts } from '../data/live-counts';
import {
  getRecentListingsNational,
  minPriceForCityModel,
  type ListingVariant,
  type ListingTone,
} from '../data/catalog-stubs';
import { faqPage, itemList } from '../lib/schema-graph';

// LAUNCH-CHECKLIST §1: every number on this page comes from the live inventory
// aggregates (liveCounts / catalog-stubs over the prod-D1 snapshot). Nothing is
// invented; zero inventory renders honest "dealers onboarding" copy instead of
// a count.
const nationalCount = liveCounts.national;
const nationalDealers = liveCounts.nationalDealers;

const BRANDS = [
  { slug: 'toyota',     name: 'Toyota' },
  { slug: 'honda',      name: 'Honda' },
  { slug: 'nissan',     name: 'Nissan' },
  { slug: 'mazda',      name: 'Mazda' },
  { slug: 'subaru',     name: 'Subaru' },
  { slug: 'lexus',      name: 'Lexus' },
  { slug: 'acura',      name: 'Acura' },
  { slug: 'infiniti',   name: 'Infiniti' },
  { slug: 'mitsubishi', name: 'Mitsubishi' },
].map((b) => ({ ...b, count: liveCounts.brand(b.slug) }));

// Latest real listings nationally; empty until partner dealers onboard.
const RECENT_LISTINGS = getRecentListingsNational(8);

/** Real national "from CA$X" floor — lowest live price across the Tier-1 CMAs. */
function nationalMinPrice(make: string, model: string): number | null {
  let min: number | null = null;
  for (const c of TIER_1_CITIES) {
    const p = minPriceForCityModel(c.slug, make, model);
    if (p !== null && (min === null || p < min)) min = p;
  }
  return min;
}

interface HomePopularModel {
  make: string;
  model: string;
  makeSlug: string;
  modelSlug: string;
  body: string;
  variant: ListingVariant;
  tone: ListingTone;
  href: string;
}

const MODEL_SEEDS: HomePopularModel[] = [
  { make: 'Toyota', model: 'Camry',   makeSlug: 'toyota', modelSlug: 'camry',   body: 'Sedan', variant: 'sedan', tone: 'pearl',    href: '/used-cars/toyota/camry/' },
  { make: 'Honda',  model: 'Civic',   makeSlug: 'honda',  modelSlug: 'civic',   body: 'Sedan', variant: 'sedan', tone: 'silver',   href: '/used-cars/honda/civic/' },
  { make: 'Toyota', model: 'RAV4',    makeSlug: 'toyota', modelSlug: 'rav4',    body: 'SUV',   variant: 'suv',   tone: 'graphite', href: '/used-cars/toyota/rav4/' },
  { make: 'Honda',  model: 'CR-V',    makeSlug: 'honda',  modelSlug: 'cr-v',    body: 'SUV',   variant: 'suv',   tone: 'midnight', href: '/used-cars/honda/cr-v/' },
  { make: 'Mazda',  model: 'Mazda3',  makeSlug: 'mazda',  modelSlug: 'mazda3',  body: 'Hatch', variant: 'hatch', tone: 'crimson',  href: '/used-cars/mazda/mazda3/' },
  { make: 'Subaru', model: 'Outback', makeSlug: 'subaru', modelSlug: 'outback', body: 'Wagon', variant: 'wagon', tone: 'forest',   href: '/used-cars/subaru/outback/' },
];

const POPULAR_MODELS = MODEL_SEEDS.map((m) => ({
  ...m,
  from: nationalMinPrice(m.makeSlug, m.modelSlug),
}));

const CITY_LINKS = TIER_1_CITIES.map((c) => ({
  slug: c.slug,
  name: c.name,
  province: c.province,
  count: liveCounts.city(c.slug),
}));

const FAQ_ITEMS: FaqItem[] = [
  {
    q: 'Why are Japanese cars popular in Canada?',
    a: 'Japanese-built cars consistently rank among the top for long-term reliability and resale value in Canadian conditions. Brands like Toyota, Honda and Subaru are over-represented in vehicles that pass 250,000 km without major repairs, which matters in a country where winter driving and long highway commutes are common.',
  },
  {
    q: 'Do I need an AMVIC-registered dealer in Alberta?',
    a: "Yes. In Alberta, anyone who sells more than four vehicles a year must be licensed by AMVIC (Alberta Motor Vehicle Industry Council). Buying from a licensed dealer means access to the consumer compensation fund and recourse if something goes wrong. Every Alberta listing on japanauto.ca shows the dealer's AMVIC number.",
  },
  {
    q: "What's the difference between OEM and aftermarket parts?",
    a: "OEM (Original Equipment Manufacturer) parts are made by or for the original carmaker and match factory spec exactly. Aftermarket parts are made by third parties — they're usually cheaper and sometimes better, but quality varies. For safety-critical components like brakes and airbags, most owners stay with OEM.",
  },
  {
    q: 'How do I check a VIN before buying?',
    a: 'Run the 17-digit VIN through CarFax Canada or a similar history service. Check that the VIN on the windshield, doorjamb and registration all match. A VIN history can reveal accident reports, previous registrations across provinces, and any salvage or rebuilt title brands.',
  },
  {
    q: 'What taxes apply when buying a used car in Canada?',
    a: 'Tax depends on the province where you register the vehicle. Most provinces apply GST/HST or PST on top of the purchase price; Alberta has no provincial sales tax on private sales but charges 5% GST through dealers. Always confirm the total before you sign the bill of sale.',
  },
  {
    q: 'Are salvage-title Japanese cars worth it?',
    a: 'Sometimes — but go in with eyes open. A salvage or rebuilt title means the vehicle was once a total loss. Even after repair, resale value and insurability are lower. They can be reasonable for daily drivers if a qualified mechanic inspects the structural repairs first.',
  },
];

// Homepage editorial module — driven by the REAL, published blog collection
// (deep-audit WEB-3). The prior hardcoded list linked 3 never-authored slugs
// with fabricated read-times/dates; this pulls title/excerpt/date from the
// collection and computes read-time from the actual body, so it can never
// drift into 404s or invented metadata. A curated slug that is missing or
// unpublished is dropped and back-filled from the newest published posts.
const CURATED = [
  { slug: 'how-to-buy-used-toyota-camry-calgary', cat: 'Buying guide', tone: '#1F2530' },
  { slug: 'mazda-cx5-vs-crv-vs-rav4',             cat: 'Comparison',   tone: '#2F3D2F' },
  { slug: 'used-jdm-import-riv-process',          cat: 'Import & regs', tone: '#3A3A3D' },
];
const publishedPosts = (await getCollection('blog'))
  .filter((p) => p.data.body_status === 'published');
const byId = new Map(publishedPosts.map((p) => [p.data.slug, p]));
const TONES = ['#1F2530', '#2F3D2F', '#3A3A3D'];
const readMins = (body: string) => `${Math.max(1, Math.round((body.trim().split(/\s+/).length) / 200))} min read`;
const chosen = [
  ...CURATED.filter((c) => byId.has(c.slug)),
  ...publishedPosts
    .filter((p) => !CURATED.some((c) => c.slug === p.data.slug))
    .map((p, i) => ({ slug: p.data.slug, cat: 'From the blog', tone: TONES[i % TONES.length]! })),
].slice(0, 3);
const BLOG_ARTICLES: BlogArticle[] = chosen.map((c) => {
  const post = byId.get(c.slug)!;
  return {
    cat: c.cat,
    title: post.data.title,
    excerpt: post.data.tldr_draft,
    read: readMins(post.body ?? ''),
    date: post.data.pub_date ? String(post.data.pub_date).slice(0, 10) : '',
    tone: c.tone,
    slug: c.slug,
  };
});

const GLOSSARY_TERMS: GlossaryTerm[] = [
  { term: 'AMVIC', def: "Alberta's dealer licensing body." },
  { term: 'AWD',   def: 'All-wheel drive — power to all four wheels.' },
  { term: 'CVT',   def: 'Continuously variable transmission.' },
  { term: 'OEM',   def: 'Original Equipment Manufacturer parts.' },
  { term: 'JDM',   def: 'Japanese Domestic Market vehicles.' },
  { term: 'VIN',   def: '17-digit vehicle identification number.' },
];

const SITE = 'https://japanauto.ca';

// Page-level structured data, merged into the BaseLayout @graph (Organization +
// WebSite). FAQPage mirrors the visible FaqSection 1:1; two ItemLists expose the
// model and city collections to search crawlers and answer engines. Helpers
// return null when empty, so each is spread in only when present (type-safe).
const homeFaq = faqPage(
  FAQ_ITEMS.map((f) => f.q),
  FAQ_ITEMS.map((f) => f.a),
);
const modelsList = itemList(
  POPULAR_MODELS.map((m) => ({
    name: `${m.make} ${m.model}`,
    url: `${SITE}${m.href}`,
  })),
  'Popular used Japanese models in Canada',
);
const citiesList = itemList(
  CITY_LINKS.map((c) => ({
    name: `Used Japanese cars in ${c.name}`,
    url: `${SITE}/${c.slug}/`,
  })),
  'Browse used Japanese cars by Canadian city',
);
const schemaLD = [
  ...(homeFaq ? [homeFaq] : []),
  ...(modelsList ? [modelsList] : []),
  ...(citiesList ? [citiesList] : []),
];

const title = 'Used Japanese cars and parts in Canada — japanauto.ca';
const description = 'Find used Toyota, Honda, Nissan, Mazda, Subaru, Lexus, Acura, Infiniti, Mitsubishi cars from local Canadian dealers. AMVIC-verified, VIN-checked listings.';
---
<BaseLayout {title} {description} canonical="https://japanauto.ca/" {schemaLD}>
  <Navbar slot="navbar" />
  <MenuDrawer slot="menu-drawer" />
  <CityPickerDialog slot="city-picker" />
  <Footer slot="footer" />

  <h1 class="sr-only">Used Japanese cars and parts across Canada — japanauto.ca</h1>

  <section style="padding-block:24px 8px" class="gutter">
    <p class="t-body-l ink-strong" style="max-width:62ch;line-height:1.5">
      <strong>japanauto.ca</strong> is an independent Canadian marketplace for used Japanese cars and
      salvage-yard donor parts, aggregating AMVIC- and OMVIC-verified dealer listings across Toronto,
      Montreal, Vancouver, Calgary, Edmonton and Ottawa.
    </p>
    <p class="t-body-s ink-muted" style="font-size:13px;margin-top:10px">
      {nationalCount > 0 ? (
        <>
          <span class="num">{nationalCount.toLocaleString('en-US')}</span> used Japanese cars
          from <span class="num">{nationalDealers}</span> {nationalDealers === 1 ? 'dealer' : 'dealers'} across {TIER_1_CITIES.length} Canadian cities · Updated today ·
        </>
      ) : (
        <>Live listings appear here as local dealers onboard ·</>
      )}
      <a href="/editorial-policy/" style="color:var(--color-ink-default);text-decoration:underline">every regulatory claim is fact-checked by a licensed advisor</a>
    </p>
  </section>

  <section class="section" style="padding-top:8px">
    <div class="brand-grid-home" style="display:grid;grid-template-columns:repeat(3, 1fr);gap:8px">
      {BRANDS.map((b) => (
        <a
          href={`/used-cars/${b.slug}/`}
          class="card"
          style="display:flex;flex-direction:column;justify-content:center;padding:16px;min-height:80px;gap:4px"
        >
          <div class="t-h-s" style="font-size:14px;line-height:20px">{b.name}</div>
          <div class="t-caption" style="font-size:9px;color:var(--color-ink-muted)">
            {b.count > 0 ? `${b.count} listed` : 'Dealers onboarding'}
          </div>
        </a>
      ))}
    </div>
    <div style="display:flex;justify-content:flex-end;margin-top:16px">
      <a
        class="t-body-s"
        href="/brands/"
        style="display:inline-flex;align-items:center;gap:6px;color:var(--color-ink-default);font-size:14px"
      >
        View all brand pages
        <Icon name="arrowRight" size={14} />
      </a>
    </div>
  </section>

  {RECENT_LISTINGS.length > 0 ? (
    <ListingFeed
      heading="Latest Japanese cars across Canada"
      listings={RECENT_LISTINGS}
      ctaText="View all listings"
      ctaHref="/used-cars/"
    />
  ) : (
    <section class="section">
      <header style="margin-bottom:16px">
        <h2 class="t-h-l">Latest Japanese cars across Canada</h2>
      </header>
      <div class="card" style="padding:28px 24px;text-align:center">
        <p class="t-h-s" style="font-size:15px;line-height:21px;margin:0 0 6px">
          New inventory is arriving
        </p>
        <p class="t-body-s ink-muted" style="font-size:13px;line-height:19px;margin:0 0 14px">
          Local dealers are onboarding — live listings appear here first.
        </p>
        <a href="/dealer/signup/" class="btn btn-secondary btn-sm" style="display:inline-flex">
          List your inventory →
        </a>
      </div>
    </section>
  )}

  <section class="section">
    <header style="margin-bottom:16px">
      <h2 class="t-h-l">Popular Japanese models in Canada</h2>
    </header>
    <div class="popular-models-grid" style="display:grid;grid-template-columns:repeat(2, 1fr);gap:12px">
      {POPULAR_MODELS.map((m) => (
        <a
          href={m.href}
          class="card"
          style="overflow:hidden;display:flex;flex-direction:column;padding:14px;gap:8px;position:relative"
        >
          <div style="height:56px;width:100%;display:grid;place-items:center;background:var(--color-bg-muted);border-radius:6px">
            <div style="width:96px;height:48px">
              <CarSilhouette variant={m.variant} tone={m.tone} />
            </div>
          </div>
          <div>
            <h3 class="t-h-s" style="font-size:14px;line-height:20px">{m.make} {m.model}</h3>
            <p class="t-body-s ink-muted" style="font-size:12px;line-height:16px;margin-top:2px">
              {m.body}
            </p>
            <div style="display:flex;align-items:baseline;justify-content:space-between;margin-top:6px">
              <p class="t-body-s" style="font-size:12px;color:var(--color-ink-muted)">
                {m.from !== null ? (
                  <>from <span class="num ink-strong" style="font-weight:600;font-size:13px;letter-spacing:-0.005em">CA${m.from.toLocaleString('en-US')}</span></>
                ) : (
                  <>Browse listings</>
                )}
              </p>
              <Icon name="chevronRight" size={14} />
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <TrustStrip />

  <section class="section">
    <details>
      <summary style="display:flex;justify-content:space-between;align-items:center;list-style:none;cursor:pointer;padding:8px 0">
        <h2 class="t-h-l" style="font-size:20px">Browse by city</h2>
        <Icon name="chevronDown" size={20} />
      </summary>
      <div style="display:grid;grid-template-columns:1fr;gap:8px;margin-top:16px">
        {CITY_LINKS.map((c) => (
          <a
            href={`/${c.slug}/`}
            class="card"
            style="display:flex;align-items:center;justify-content:space-between;padding:20px;min-height:72px"
          >
            <div>
              <h3 class="t-h-m" style="font-size:17px">{c.name}</h3>
              <span class="t-caption" style="font-size:10px;margin-top:4px;display:block">
                {c.count > 0 ? `${c.count.toLocaleString('en-US')} cars` : 'Dealers onboarding'}
              </span>
            </div>
            <span class="t-caption t-mono" style="font-size:11px">{c.province}</span>
          </a>
        ))}
      </div>
    </details>
  </section>

  <PartsEntryPoint />

  <BlogExcerpt articles={BLOG_ARTICLES} />

  <GlossaryHighlights terms={GLOSSARY_TERMS} />

  <FaqSection items={FAQ_ITEMS} />

  <SellCta />
</BaseLayout>
