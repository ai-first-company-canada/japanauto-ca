---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Navbar from '../../../components/sections/Navbar.astro';
import MenuDrawer from '../../../components/sections/MenuDrawer.astro';
import CityPickerDialog from '../../../components/sections/CityPickerDialog.astro';
import Footer from '../../../components/sections/Footer.astro';
import Breadcrumb from '../../../components/atoms/Breadcrumb.astro';
import FaqAccordion from '../../../components/atoms/FaqAccordion.astro';
import { MODELS_BY_BRAND } from '../../../data/models-stubs.ts';
import {
  breadcrumbList, faqPage, faqAnswersFromBody, itemList, capitalize,
} from '../../../lib/schema-graph';

export async function getStaticPaths() {
  const brands = await getCollection('brand');
  return brands.map((b) => ({ params: { make: b.data.make }, props: { entry: b } }));
}

const { entry } = Astro.props;
const d = entry.data;
const { Content } = await render(entry);
const url = Astro.url.toString();
const makeName = capitalize(d.make);

// canadian_angle moved into body in Phase 4.2 — fall back to meta_description
// for the opening paragraph and Schema.org Brand description.
const brandDescription = d.canadian_angle ?? d.meta_description;
const headline = d.h1 ?? d.suggested_h1;

// Top 6 model tiles for this brand from the catalog stubs (Phase 1.2).
// Phase 5 will replace this with a live D1 query.
const models = (MODELS_BY_BRAND[d.make] ?? []).slice(0, 6);
const modelItemList = itemList(
  models.map((m) => ({ name: m.name, url: `https://japanauto.ca/used-cars/${d.make}/${m.slug}/` })),
  `Most popular used ${makeName} models in Canada`,
);

const faqLd = faqPage(d.faq_questions, faqAnswersFromBody(entry.body, d.faq_questions));
const schemaLD = [
  {
    '@type': 'Brand',
    '@id': `${url}#brand`,
    name: makeName,
    description: brandDescription,
    // No `sameAs`: it must point to URLs that also represent THIS entity
    // (manufacturer's official site / Wikipedia), never SERP competitors.
    // Omitted until canonical manufacturer URLs are in the brand data.
  },
  {
    '@type': 'WebPage',
    '@id': `${url}#page`,
    name: d.title_tag,
    description: d.meta_description,
    url,
    mainEntity: { '@id': `${url}#brand` },
    inLanguage: 'en-CA',
  },
  breadcrumbList(
    [
      { label: 'Home', href: '/' },
      { label: 'Brands', href: '/brands/' },
      { label: makeName },
    ],
    url,
  ),
  ...(modelItemList ? [modelItemList] : []),
  ...(faqLd ? [faqLd] : []),
];
---
<BaseLayout
  title={d.title_tag}
  description={d.meta_description}
  canonical={url}
  schemaLD={schemaLD}
>
  <Navbar slot="navbar" />
  <MenuDrawer slot="menu-drawer" />
  <CityPickerDialog slot="city-picker" />
  <Footer slot="footer" />

  <Breadcrumb
    items={[
      { label: 'Home', href: '/' },
      { label: 'Brands', href: '/brands/' },
      { label: makeName },
    ]}
  />

  <section class="section" style="padding-top:8px">
    <h1 class="t-display-l" style="font-size:32px;line-height:40px;margin-bottom:8px">{headline}</h1>
    <p class="t-body-m ink-muted" style="font-size:14px;line-height:22px;max-width:680px">{d.meta_description}</p>
  </section>

  {models.length > 0 && (
    <section class="section">
      <h2 class="t-h-l" style="font-size:20px;margin-bottom:12px">Most popular used {makeName} models</h2>
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:8px">
        {models.map((m) => (
          <a
            href={`/used-cars/${d.make}/${m.slug}/`}
            class="card"
            style="display:flex;flex-direction:column;justify-content:center;padding:16px;min-height:80px;gap:4px"
          >
            <div class="t-h-s" style="font-size:14px;line-height:20px">{m.name}</div>
            <div class="t-caption" style="font-size:9px;color:var(--color-ink-muted)">~{m.baseCount} listed</div>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="section">
    <a class="btn btn-primary" href={`/used-cars/${d.make}/`}>
      Browse all {makeName} listings →
    </a>
  </section>

  <section class="section content-prose">
    <Content />
  </section>

  {d.long_tail_keywords?.length > 0 && (
    <section class="section">
      <h2 class="t-h-l" style="font-size:20px;margin-bottom:12px">People also research</h2>
      <ul style="display:flex;flex-direction:column;gap:6px;font-size:14px;line-height:21px;color:var(--color-ink-default)">
        {d.long_tail_keywords.slice(0, 8).map((kw) => (
          <li>· {kw}</li>
        ))}
      </ul>
    </section>
  )}

  {d.body_status !== 'published' && d.faq_questions?.length > 0 && (
    <section class="section">
      <h2 class="t-h-l" style="font-size:20px;margin-bottom:12px">Common questions about {makeName}</h2>
      <div style="border-top:1px solid var(--color-divider)">
        {d.faq_questions.map((q, i) => (
          <FaqAccordion q={q} a="Detailed answer coming Phase 4.2 — see related models or browse listings above for current data." open={i < 2} />
        ))}
      </div>
    </section>
  )}

  <section class="section">
    <p class="t-body-s ink-muted" style="font-size:11px;line-height:16px;font-style:italic">
      {makeName} is a trademark of its respective owner. japanauto.ca is an independent marketplace and is not affiliated with {makeName} Canada.
    </p>
    {d.body_status === 'skeleton' && (
      <p class="t-body-s ink-muted" style="font-size:11px;line-height:16px;margin-top:6px">
        This page is a research-grade skeleton. Detailed sections are being expanded by our editorial team.
      </p>
    )}
  </section>
</BaseLayout>

<style>
  .content-prose h2 {
    font-size: 20px;
    line-height: 28px;
    font-weight: 600;
    color: var(--color-ink-strong);
    margin: 24px 0 12px;
  }
  .content-prose h3 {
    font-size: 16px;
    line-height: 24px;
    font-weight: 600;
    color: var(--color-ink-strong);
    margin: 20px 0 8px;
  }
  .content-prose p {
    font-size: 15px;
    line-height: 23px;
    color: var(--color-ink-default);
    margin-bottom: 12px;
  }
  .content-prose ul {
    list-style: none;
    margin: 8px 0 16px;
    padding: 0;
  }
  .content-prose li {
    font-size: 14px;
    line-height: 22px;
    color: var(--color-ink-default);
    padding-left: 16px;
    position: relative;
  }
  .content-prose li::before {
    content: '·';
    position: absolute;
    left: 4px;
    top: 0;
  }
</style>
