---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/sections/Navbar.astro';
import MenuDrawer from '../../components/sections/MenuDrawer.astro';
import CityPickerDialog from '../../components/sections/CityPickerDialog.astro';
import Footer from '../../components/sections/Footer.astro';
import Breadcrumb from '../../components/atoms/Breadcrumb.astro';
import PageHeading from '../../components/sections/PageHeading.astro';
import catalogLive from '../../data/catalog-live.json';

// Real sellers only (LAUNCH-CHECKLIST §1): the build-time prod-D1 snapshot
// replaces the 12 fabricated dealer profiles whose links all 404ed. Cards
// render only sellers with live inventory; zero → honest onboarding state.
interface LiveDealer {
  slug: string; name: string; city: string; province: string; type: string;
  listing_count: number; donor_count: number;
}
const dealers = ((catalogLive as { dealers?: LiveDealer[] }).dealers ?? [])
  .filter((d) => d.listing_count + d.donor_count > 0);
const totalListings = dealers.reduce((s, d) => s + d.listing_count + d.donor_count, 0);

const title = 'Used Japanese car dealers across Canada — japanauto.ca';
const description = dealers.length > 0
  ? `${dealers.length} licensed Japanese car dealer${dealers.length === 1 ? '' : 's'} on japanauto.ca. AMVIC, OMVIC, and provincial-licensed sellers with live inventory.`
  : 'Licensed Japanese car dealers on japanauto.ca — AMVIC, OMVIC and provincial-licensed sellers join here first. Dealer onboarding is open.';
const canonical = 'https://japanauto.ca/dealers/';

const schemaLD = [
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://japanauto.ca/' },
      { '@type': 'ListItem', position: 2, name: 'Dealers', item: canonical },
    ],
  },
  // AutoDealer ItemList only for real sellers — fabricated entities in
  // structured data are manual-action territory.
  ...(dealers.length > 0 ? [{
    '@type': 'ItemList',
    name: 'Japanese car dealers in Canada',
    numberOfItems: dealers.length,
    itemListElement: dealers.map((d, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'AutoDealer',
        '@id': `https://japanauto.ca/dealers/${d.slug}/#dealer`,
        name: d.name,
        url: `https://japanauto.ca/dealers/${d.slug}/`,
        address: {
          '@type': 'PostalAddress',
          addressLocality: d.city,
          addressRegion: d.province,
          addressCountry: 'CA',
        },
      },
    })),
  }] : []),
];

const subtitle = dealers.length > 0
  ? `<span class="num">${dealers.length}</span> licensed dealer${dealers.length === 1 ? '' : 's'} · <span class="num">${totalListings.toLocaleString('en-US')}</span> live listing${totalListings === 1 ? '' : 's'}`
  : 'Licensed sellers are onboarding — profiles appear here first';
---
<BaseLayout {title} {description} {canonical} {schemaLD}>
  <Navbar slot="navbar" />
  <MenuDrawer slot="menu-drawer" />
  <CityPickerDialog slot="city-picker" />
  <Footer slot="footer" />

  <h1 class="sr-only">Japanese car dealers across Canada</h1>

  <Breadcrumb items={[
    { label: 'Home', href: '/' },
    { label: 'Dealers' },
  ]} />

  <PageHeading title="Used Japanese car dealers across Canada" subtitle={subtitle} />

  <section style="padding:0 16px 32px">
    {dealers.length > 0 ? (
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
        {dealers.map((d) => (
          <a
            href={`/dealers/${d.slug}/`}
            class="card"
            style="overflow:hidden;display:flex;flex-direction:column;padding:14px;gap:6px;text-decoration:none"
          >
            <span class="t-h-s" style="font-size:14px;line-height:18px;font-weight:600;color:var(--color-ink-strong)">
              {d.name}
            </span>
            <span style="font-size:11px;color:var(--color-ink-muted);letter-spacing:0.04em">
              {d.type === 'salvage_yard' ? 'Salvage yard' : 'Dealer'}
            </span>
            <span style="font-size:13px;color:var(--color-ink-default);margin-top:auto">
              {d.city.charAt(0).toUpperCase() + d.city.slice(1)}, {d.province}
            </span>
            <span class="num" style="font-size:12px;color:var(--color-ink-strong);font-weight:600">
              {d.listing_count + d.donor_count} listing{d.listing_count + d.donor_count === 1 ? '' : 's'}
            </span>
          </a>
        ))}
      </div>
    ) : (
      <div class="card" style="padding:28px 24px;text-align:center">
        <p class="t-h-s" style="font-size:15px;line-height:21px;margin:0 0 6px">
          Dealer profiles are coming online
        </p>
        <p class="t-body-s ink-muted" style="font-size:13px;line-height:19px;margin:0 0 14px">
          AMVIC- and OMVIC-licensed dealers and salvage yards are onboarding now.
          Every profile here is a real, licensed business — no filler.
        </p>
        <a href="/dealer/signup/" class="btn btn-secondary btn-sm" style="display:inline-flex">
          Join as a dealer — first 30 days of Pro free →
        </a>
      </div>
    )}
  </section>

  <section style="padding:0 16px 48px">
    <h2 class="t-h-s" style="font-size:18px;font-weight:600;margin:0 0 12px;color:var(--color-ink-strong)">
      About japanauto.ca dealer network
    </h2>
    <p style="font-size:14px;line-height:21px;color:var(--color-ink-default);margin:0 0 12px">
      japanauto.ca aggregates used Japanese vehicle inventory from independent dealers across Canada. All Alberta dealers in our directory hold an AMVIC license; Ontario dealers are OMVIC-registered; Quebec dealers are licensed by the OPC.
    </p>
    <p style="font-size:14px;line-height:21px;color:var(--color-ink-default);margin:0">
      Each dealer profile lists current inventory, opening hours, address, and direct contact methods. We do not handle transactions — buyers contact the dealer directly via the listing page.
    </p>
  </section>
</BaseLayout>
