---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Navbar from '../../../components/sections/Navbar.astro';
import MenuDrawer from '../../../components/sections/MenuDrawer.astro';
import CityPickerDialog from '../../../components/sections/CityPickerDialog.astro';
import Footer from '../../../components/sections/Footer.astro';
import Breadcrumb from '../../../components/atoms/Breadcrumb.astro';

const url = Astro.url.toString();
const schemaLD = [
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://japanauto.ca/' },
      { '@type': 'ListItem', position: 2, name: 'Dealers', item: 'https://japanauto.ca/dealers/' },
      { '@type': 'ListItem', position: 3, name: 'How it works', item: url },
    ],
  },
];

const STEPS = [
  {
    t: 'Create your account',
    d: 'Sign up with your dealership or salvage-yard details. Alberta sellers add their AMVIC licence number — it shows on every listing and buyers can verify it on the public registry. Every new account starts with 30 days of Pro, free, no card.',
  },
  {
    t: 'List a vehicle in minutes',
    d: 'Enter the VIN and we decode year, make, model, transmission, fuel and factory equipment automatically. Add mileage, price and photos. One click on "Improve text" turns your draft into clean buyer-ready copy — you review before publishing, nothing posts without you.',
  },
  {
    t: 'Buyers contact you directly',
    d: 'Your phone and email are on the listing with your licence badge. japanauto.ca never sits in the middle of the deal — no commissions, no lead reselling.',
  },
  {
    t: 'Track what works',
    d: 'Every listing has live statistics: views, contacts, conversion. Pro accounts also see private market context — how your price compares to similar cars on the open market in your city. Only you see it.',
  },
];
---
<BaseLayout
  title="How it works for dealers — japanauto.ca"
  description="List used Japanese cars in minutes: VIN-decoded listings, AI text improver, direct buyer contact, live stats. 30-day free Pro trial for licensed dealers."
  canonical={url}
  schemaLD={schemaLD}
>
  <Navbar slot="navbar" />
  <MenuDrawer slot="menu-drawer" />
  <CityPickerDialog slot="city-picker" />
  <Footer slot="footer" />

  <Breadcrumb items={[
    { label: 'Home', href: '/' },
    { label: 'Dealers', href: '/dealers/' },
    { label: 'How it works' },
  ]} />

  <article class="section" style="padding-top:8px;max-width:720px">
    <h1 class="t-display-l" style="font-size:30px;line-height:38px;margin-bottom:8px">How japanauto.ca works for dealers</h1>
    <p class="t-body-m ink-muted" style="font-size:15px;line-height:23px;margin-bottom:24px">
      A marketplace built for licensed Canadian sellers of Japanese cars and parts donor cars —
      dealerships and salvage yards.
    </p>

    {STEPS.map((s, i) => (
      <div style="display:flex;gap:14px;margin-bottom:18px">
        <span class="num" style="flex:0 0 32px;height:32px;border-radius:50%;background:var(--color-ink-strong);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:600">{i + 1}</span>
        <div>
          <h2 class="t-h-s" style="font-size:16px;line-height:22px;margin:0 0 4px">{s.t}</h2>
          <p class="t-body-m" style="font-size:14px;line-height:21px;margin:0;color:var(--color-ink-default)">{s.d}</p>
        </div>
      </div>
    ))}

    <div style="display:flex;gap:10px;margin-top:28px">
      <a href="/dealer/signup/" class="btn btn-primary" style="flex:1">Start free trial</a>
      <a href="/dealers/pricing/" class="btn btn-secondary" style="flex:1">See pricing</a>
    </div>
  </article>
</BaseLayout>
