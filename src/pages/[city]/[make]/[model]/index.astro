---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Navbar from '../../../../components/sections/Navbar.astro';
import MenuDrawer from '../../../../components/sections/MenuDrawer.astro';
import CityPickerDialog from '../../../../components/sections/CityPickerDialog.astro';
import Footer from '../../../../components/sections/Footer.astro';
import Breadcrumb from '../../../../components/atoms/Breadcrumb.astro';
import PageHeading from '../../../../components/sections/PageHeading.astro';
import FilterPillBar from '../../../../components/sections/FilterPillBar.astro';
import CatalogList from '../../../../components/sections/CatalogList.astro';
import CatalogPagination from '../../../../components/sections/CatalogPagination.astro';
import ModelCrossLinks from '../../../../components/sections/ModelCrossLinks.astro';
import FaqSection from '../../../../components/sections/FaqSection.astro';
import YearFilterDialog from '../../../../components/sections/YearFilterDialog.astro';
import SortFilterDialog from '../../../../components/sections/SortFilterDialog.astro';
import { BRAND_CONTENT, TIER_1_CITIES } from '../../../../data/brand-content';
import { MODELS_BY_BRAND, getModelsForCity } from '../../../../data/models-stubs';
import { getCatalogForModelCity } from '../../../../data/catalog-stubs';

export function getStaticPaths() {
  const paths: Array<{ params: { city: string; make: string; model: string } }> = [];
  for (const city of TIER_1_CITIES) {
    for (const make of Object.keys(MODELS_BY_BRAND)) {
      for (const model of MODELS_BY_BRAND[make]!) {
        paths.push({ params: { city: city.slug, make, model: model.slug } });
      }
    }
  }
  return paths;
}

const { make, model, city } = Astro.params;
const brand = BRAND_CONTENT[make!]!;
const cityInfo = TIER_1_CITIES.find((c) => c.slug === city)!;
const modelInfo = MODELS_BY_BRAND[make!]!.find((m) => m.slug === model)!;
const catalog = getCatalogForModelCity(make!, model!, modelInfo.name, city!);
const cityShort = `${cityInfo.name}, ${cityInfo.province}`;

const otherModels = getModelsForCity(make!, city!);

const modelFaqs = [
  {
    q: `Is the ${brand.name} ${modelInfo.name} reliable?`,
    a: `${brand.name} models including the ${modelInfo.name} consistently rank in the top tier for long-term reliability across Canadian conditions.`,
  },
  {
    q: `What years of ${brand.name} ${modelInfo.name} are available?`,
    a: `Used ${brand.name} ${modelInfo.name} listings on japanauto.ca cover model years from 2016 to current — the rolling 10-year window for used inventory.`,
  },
  {
    q: `Does the ${brand.name} ${modelInfo.name} have AWD?`,
    a: `AWD availability depends on year and trim. Most ${brand.name} ${modelInfo.name} listings show drivetrain in the spec line. Filter by drive on the listing detail page.`,
  },
  {
    q: `What's the typical price range for a used ${brand.name} ${modelInfo.name}?`,
    a: `Pricing depends on year, mileage, and trim. As a rule, expect roughly 10-15% depreciation per year on top trims, more on base trims.`,
  },
];

const title = `Used ${brand.name} ${modelInfo.name} in ${cityInfo.name}, ${cityInfo.province} — japanauto.ca`;
// Real counts only — zero inventory gets honest "onboarding" copy, never an
// invented number (LAUNCH-CHECKLIST §1).
const description = catalog.totalCount > 0
  ? `${catalog.totalCount} used ${brand.name} ${modelInfo.name} listing${catalog.totalCount === 1 ? '' : 's'} in ${cityInfo.name}. AMVIC-verified dealers, VIN-checked vehicles, prices in CA$.`
  : `Used ${brand.name} ${modelInfo.name} for sale in ${cityInfo.name} from AMVIC-licensed dealers — VIN-checked listings appear here as local dealers onboard.`;
const canonical = `https://japanauto.ca/${city}/${make}/${model}/`;

const allListings = [...catalog.boosted, ...catalog.organic];
const schemaLD = [
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://japanauto.ca/' },
      { '@type': 'ListItem', position: 2, name: cityInfo.name, item: `https://japanauto.ca/${city}/` },
      { '@type': 'ListItem', position: 3, name: brand.name, item: `https://japanauto.ca/${city}/${make}/` },
      { '@type': 'ListItem', position: 4, name: modelInfo.name, item: canonical },
    ],
  },
  // Vehicle/Offer markup only when real rows exist — catalog data is live D1
  // (catalog-live.json) since 2026-06-12; an empty combo emits no ItemList.
  ...(allListings.length === 0 ? [] : [{
    '@type': 'ItemList',
    name: `Used ${brand.name} ${modelInfo.name} in ${cityInfo.name}`,
    numberOfItems: catalog.totalCount,
    itemListElement: allListings.map((l, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'Vehicle',
        name: `${l.year} ${l.make} ${l.model} ${l.trim}`.trim(),
        vehicleModelDate: String(l.year),
        mileageFromOdometer: { '@type': 'QuantitativeValue', value: l.km, unitCode: 'KMT' },
        ...(l.transmission ? { vehicleTransmission: l.transmission } : {}),
        ...(l.drive ? { driveWheelConfiguration: l.drive } : {}),
        url: `https://japanauto.ca/used-cars/listing/${l.slug}/`,
        offers: {
          '@type': 'Offer',
          price: l.price,
          priceCurrency: 'CAD',
          availability: 'https://schema.org/InStock',
          seller: { '@type': 'AutoDealer', name: l.dealer },
        },
      },
    })),
  }]),
  {
    '@type': 'Place',
    name: cityInfo.name,
    address: {
      '@type': 'PostalAddress',
      addressLocality: cityInfo.name,
      addressRegion: cityInfo.province,
      addressCountry: 'CA',
    },
  },
  // The featured slot is a house ad (brand-site link, no price, no seller —
  // ADR-0013) and must not emit Offer markup. Paid featured_slots get their
  // own JSON-LD design when the D1 catalog wiring lands.
  {
    '@type': 'FAQPage',
    mainEntity: modelFaqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
];

const subtitleHtml = catalog.totalCount > 0
  ? `<span class="num">${catalog.totalCount}</span> listing${catalog.totalCount === 1 ? '' : 's'} from <span class="num">${catalog.dealerCount}</span> dealer${catalog.dealerCount === 1 ? '' : 's'} · Updated with every listing`
  : `Local dealers are onboarding — live listings appear here first`;
const visibleCount = catalog.boosted.length + catalog.organic.length;
---
<BaseLayout
  {title}
  {description}
  {canonical}
  {schemaLD}
>
  <Navbar slot="navbar" cityShort={cityShort} />
  <MenuDrawer slot="menu-drawer" cityShort={cityShort} cityName={cityInfo.name} />
  <CityPickerDialog slot="city-picker" />
  <YearFilterDialog slot="filter-dialogs" />
  <SortFilterDialog slot="filter-dialogs" />
  <Footer slot="footer" />

  <h1 class="sr-only">{`Used ${brand.name} ${modelInfo.name} in ${cityInfo.name}, ${cityInfo.province}`}</h1>

  <Breadcrumb items={[
    { label: 'Home', href: '/' },
    { label: cityInfo.name, href: `/${city}/` },
    { label: brand.name, href: `/${city}/${make}/` },
    { label: modelInfo.name },
  ]} />

  <PageHeading
    title={`Used ${brand.name} ${modelInfo.name} in ${cityShort}`}
    subtitle={subtitleHtml}
  />

  <FilterPillBar />

  {visibleCount > 0 && (
    <p
      id="catalog-counter"
      class="t-body-s ink-muted"
      style="padding:12px 16px 0;font-size:12px"
    >
      Showing <span class="num">{visibleCount}</span> of <span class="num">{catalog.totalCount}</span> listings
    </p>
  )}

  <CatalogList
    featured={catalog.featured}
    boosted={catalog.boosted}
    organic={catalog.organic}
    citySlug={city!}
    emptyContext={{ modelLabel: `${brand.name} ${modelInfo.name}`, cityName: cityInfo.name, brandSlug: make!, brandName: brand.name }}
  />

  <CatalogPagination initialShown={10} />

  <ModelCrossLinks
    brandSlug={make!}
    brandName={brand.name}
    citySlug={city!}
    cityName={cityInfo.name}
    currentModelSlug={model!}
    crossLinks={otherModels}
  />

  <FaqSection
    items={modelFaqs}
    heading={`Common questions about ${brand.name} ${modelInfo.name}`}
  />

  <script is:inline>
    (function () {
      window.applyCatalogFilters = function () {
        var params = new URLSearchParams(window.location.search);
        var rawYear = params.get('year') || '';
        var yearFilter = rawYear.split(',').filter(Boolean);
        var sortKey = params.get('sort') || 'newest';
        var grid = document.getElementById('catalog-grid');
        if (!grid) return;
        var cards = Array.prototype.slice.call(grid.querySelectorAll('[data-year]'));
        var visible = 0;
        for (var i = 0; i < cards.length; i++) {
          var card = cards[i];
          var year = card.getAttribute('data-year');
          var matchYear = yearFilter.length === 0 || yearFilter.indexOf(year) !== -1;
          if (matchYear) {
            card.style.display = '';
            visible++;
          } else {
            card.style.display = 'none';
          }
        }
        var visibleCards = cards.filter(function (c) { return c.style.display !== 'none'; });
        visibleCards.sort(function (a, b) {
          var aTier = a.getAttribute('data-tier') === 'boosted' ? 0 : 1;
          var bTier = b.getAttribute('data-tier') === 'boosted' ? 0 : 1;
          if (aTier !== bTier) return aTier - bTier;
          if (sortKey === 'price-asc') {
            return Number(a.getAttribute('data-price')) - Number(b.getAttribute('data-price'));
          }
          if (sortKey === 'price-desc') {
            return Number(b.getAttribute('data-price')) - Number(a.getAttribute('data-price'));
          }
          if (sortKey === 'km-asc') {
            return Number(a.getAttribute('data-mileage')) - Number(b.getAttribute('data-mileage'));
          }
          if (sortKey === 'year-desc') {
            return Number(b.getAttribute('data-year')) - Number(a.getAttribute('data-year'));
          }
          return 0;
        });
        for (var j = 0; j < visibleCards.length; j++) {
          grid.appendChild(visibleCards[j]);
        }
        var counter = document.getElementById('catalog-counter');
        if (counter) {
          counter.innerHTML = 'Showing <span class="num">' + visible + '</span> of <span class="num">' + cards.length + '</span> listings';
        }
        document.dispatchEvent(new CustomEvent('catalog-filtered'));
      };

      function init() {
        if (window.location.search) {
          window.applyCatalogFilters();
        } else {
          document.dispatchEvent(new CustomEvent('catalog-filtered'));
        }
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    })();
  </script>
</BaseLayout>
