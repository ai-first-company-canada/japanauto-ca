---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/sections/Navbar.astro';
import MenuDrawer from '../../components/sections/MenuDrawer.astro';
import CityPickerDialog from '../../components/sections/CityPickerDialog.astro';
import Footer from '../../components/sections/Footer.astro';
import Breadcrumb from '../../components/atoms/Breadcrumb.astro';
import PageHeading from '../../components/sections/PageHeading.astro';
import BrandGrid from '../../components/atoms/BrandGrid.astro';
import CarSilhouette from '../../components/atoms/CarSilhouette.astro';
import ListingFeed from '../../components/sections/ListingFeed.astro';
import TrustStrip from '../../components/sections/TrustStrip.astro';
import PartsEntryPoint from '../../components/sections/PartsEntryPoint.astro';
import FaqSection, { type FaqItem } from '../../components/sections/FaqSection.astro';
import CrossLinksBand from '../../components/sections/CrossLinksBand.astro';
import Icon from '../../components/atoms/Icon.astro';
import { TIER_1_CITIES, BRAND_CONTENT } from '../../data/brand-content';
import { liveCounts } from '../../data/live-counts';
import {
  getRecentListingsForCity,
  minPriceForCityModel,
  type ListingVariant,
  type ListingTone,
} from '../../data/catalog-stubs';
import { faqPage } from '../../lib/schema-graph';

export function getStaticPaths() {
  return TIER_1_CITIES.map((c) => ({ params: { city: c.slug } }));
}

const { city } = Astro.params;
const cityInfo = TIER_1_CITIES.find((c) => c.slug === city)!;

const plural = (n: number) => (n === 1 ? '' : 's');

const BRAND_SLUGS = ['toyota','honda','nissan','mazda','subaru','lexus','acura','infiniti','mitsubishi'] as const;

// LAUNCH-CHECKLIST §1: every count on this page comes from liveCounts
// (build-time prod-D1 snapshot) — nothing is invented or scaled.
const brands = BRAND_SLUGS.map((slug) => ({
  slug,
  name: BRAND_CONTENT[slug]!.name,
  count: liveCounts.cityBrand(city!, slug),
}));

const totalCount = liveCounts.city(city!);
const dealerCount = liveCounts.cityDealers(city!);

const LISTINGS = getRecentListingsForCity(city!, 8);

// Popular-model cards keep their links always; the "from CA$X" line renders
// only when a real live floor price exists for this city × model.
interface CityModelCard {
  make: string;
  model: string;
  makeSlug: string;
  modelSlug: string;
  body: string;
  variant: ListingVariant;
  tone: ListingTone;
}

const POPULAR_MODELS_BASE: CityModelCard[] = [
  { make: 'Toyota', model: 'Camry',   makeSlug: 'toyota', modelSlug: 'camry',   body: 'Sedan', variant: 'sedan', tone: 'pearl' },
  { make: 'Honda',  model: 'Civic',   makeSlug: 'honda',  modelSlug: 'civic',   body: 'Sedan', variant: 'sedan', tone: 'silver' },
  { make: 'Toyota', model: 'RAV4',    makeSlug: 'toyota', modelSlug: 'rav4',    body: 'SUV',   variant: 'suv',   tone: 'graphite' },
  { make: 'Honda',  model: 'CR-V',    makeSlug: 'honda',  modelSlug: 'cr-v',    body: 'SUV',   variant: 'suv',   tone: 'midnight' },
  { make: 'Mazda',  model: 'Mazda3',  makeSlug: 'mazda',  modelSlug: 'mazda3',  body: 'Hatch', variant: 'hatch', tone: 'crimson' },
  { make: 'Subaru', model: 'Outback', makeSlug: 'subaru', modelSlug: 'outback', body: 'Wagon', variant: 'wagon', tone: 'forest' },
];

const POPULAR_MODELS = POPULAR_MODELS_BASE.map((m) => ({
  ...m,
  from: minPriceForCityModel(city!, m.makeSlug, m.modelSlug),
}));

const FAQ_ITEMS: FaqItem[] = [
  {
    q: `How many used Japanese cars are listed in ${cityInfo.name}?`,
    a: totalCount > 0
      ? `There are currently ${totalCount.toLocaleString('en-US')} live listing${plural(totalCount)} from ${dealerCount} local dealer${plural(dealerCount)} in the ${cityInfo.name} CMA. Every listing is a real car from a licensed local seller.`
      : 'Inventory is live and growing as AMVIC-licensed dealers onboard — every listing is a real car from a licensed local seller.',
  },
  {
    q: `Which Japanese brand is most popular in ${cityInfo.name}?`,
    a: `Toyota and Honda routinely lead used-car sales across all major Canadian metros. In ${cityInfo.name} specifically the Civic, Corolla and RAV4 are the highest-volume models year over year.`,
  },
  {
    q: 'Why are Japanese cars popular in Canada?',
    a: 'Japanese-built cars consistently rank among the top for long-term reliability and resale value in Canadian conditions. Brands like Toyota, Honda and Subaru are over-represented in vehicles that pass 250,000 km without major repairs.',
  },
  {
    q: 'How do I check a VIN before buying?',
    a: 'Run the 17-digit VIN through CarFax Canada or a similar history service. Check that the VIN on the windshield, doorjamb and registration all match. A VIN history can reveal accident reports, previous registrations across provinces, and any salvage or rebuilt title brands.',
  },
];

const title = `Used Japanese cars and parts in ${cityInfo.name}, ${cityInfo.province} — japanauto.ca`;
const description = totalCount > 0
  ? `Browse ${totalCount.toLocaleString('en-US')} live listing${plural(totalCount)} from ${dealerCount} licensed ${cityInfo.name} dealer${plural(dealerCount)} — used Toyota, Honda, Nissan, Mazda, Subaru and Lexus cars.`
  : `Find used Toyota, Honda, Nissan, Mazda, Subaru, Lexus, Acura and Infiniti cars from local ${cityInfo.name} dealers. Live listings as licensed dealers onboard.`;
const canonical = `https://japanauto.ca/${city}/`;

const faqLd = faqPage(FAQ_ITEMS.map((f) => f.q), FAQ_ITEMS.map((f) => f.a));
const schemaLD = [
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://japanauto.ca/' },
      { '@type': 'ListItem', position: 2, name: cityInfo.name, item: canonical },
    ],
  },
  ...(faqLd ? [faqLd] : []),
  {
    '@type': 'Place',
    name: cityInfo.name,
    address: {
      '@type': 'PostalAddress',
      addressLocality: cityInfo.name,
      addressRegion: cityInfo.province,
      addressCountry: 'CA',
    },
  },
];

const subtitleHtml = totalCount > 0
  ? `<span class="num">${totalCount.toLocaleString('en-US')}</span> Japanese car${plural(totalCount)} from <span class="num">${dealerCount}</span> local dealer${plural(dealerCount)} in ${cityInfo.name} · Live inventory`
  : `Live listings appear here as local ${cityInfo.name} dealers onboard · Every listing is a real car from a licensed seller`;
---
<BaseLayout
  {title}
  {description}
  {canonical}
  {schemaLD}
>
  <Navbar slot="navbar" cityShort={`${cityInfo.name}, ${cityInfo.province}`} />
  <MenuDrawer slot="menu-drawer" cityShort={`${cityInfo.name}, ${cityInfo.province}`} cityName={cityInfo.name} />
  <CityPickerDialog slot="city-picker" />
  <Footer slot="footer" />

  <h1 class="sr-only">{`Used Japanese cars and parts in ${cityInfo.name}, ${cityInfo.province}`}</h1>

  <Breadcrumb items={[
    { label: 'Home', href: '/' },
    { label: cityInfo.name },
  ]} />

  <PageHeading
    title={`Used Japanese cars in ${cityInfo.name}`}
    subtitle={subtitleHtml}
  />

  <section class="section" style="padding-top:8px">
    <BrandGrid brands={brands} citySlug={city!} />
    <div style="display:flex;justify-content:flex-end;margin-top:16px">
      <a
        class="t-body-s"
        href="/brands/"
        style="display:inline-flex;align-items:center;gap:6px;color:var(--color-ink-default);font-size:14px"
      >
        View all brand pages
        <Icon name="arrowRight" size={14} />
      </a>
    </div>
  </section>

  {LISTINGS.length > 0 ? (
    <ListingFeed
      heading={`Latest Japanese cars in ${cityInfo.name}`}
      listings={LISTINGS}
      ctaText="View all listings"
      ctaHref="/used-cars/"
      cityName={cityInfo.name}
      totalCount={totalCount}
    />
  ) : (
    <section class="section">
      <header style="margin-bottom:16px">
        <h2 class="t-h-l">{`Latest Japanese cars in ${cityInfo.name}`}</h2>
      </header>
      <div class="card" style="padding:20px">
        <p class="t-h-s" style="font-size:15px;line-height:21px;margin:0 0 6px">New inventory is arriving</p>
        <p class="t-body-s ink-muted" style="font-size:13px;line-height:19px;margin:0 0 14px">
          Local dealers are onboarding — live listings appear here first.
        </p>
        <a href="/dealer/signup/" class="btn btn-secondary btn-sm" style="display:inline-flex">
          List your inventory →
        </a>
      </div>
    </section>
  )}

  <section class="section">
    <header style="margin-bottom:16px">
      <h2 class="t-h-l">Most-searched Japanese models near {cityInfo.name}</h2>
    </header>
    <div class="popular-models-grid" style="display:grid;grid-template-columns:repeat(2, 1fr);gap:12px">
      {POPULAR_MODELS.map((m) => (
        <a
          href={`/${city}/${m.makeSlug}/${m.modelSlug}/`}
          class="card"
          style="overflow:hidden;display:flex;flex-direction:column;padding:14px;gap:8px;position:relative"
        >
          <div style="height:56px;width:100%;display:grid;place-items:center;background:var(--color-bg-muted);border-radius:6px">
            <div style="width:96px;height:48px">
              <CarSilhouette variant={m.variant} tone={m.tone} />
            </div>
          </div>
          <div>
            <h3 class="t-h-s" style="font-size:14px;line-height:20px">{m.make} {m.model}</h3>
            <p class="t-body-s ink-muted" style="font-size:12px;line-height:16px;margin-top:2px">
              {m.body}
            </p>
            <div style={`display:flex;align-items:baseline;justify-content:${m.from !== null ? 'space-between' : 'flex-end'};margin-top:6px`}>
              {m.from !== null && (
                <p class="t-body-s" style="font-size:12px;color:var(--color-ink-muted)">
                  from <span class="num ink-strong" style="font-weight:600;font-size:13px;letter-spacing:-0.005em">CA${m.from.toLocaleString('en-US')}</span>
                </p>
              )}
              <Icon name="chevronRight" size={14} />
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <TrustStrip />

  <PartsEntryPoint citySlug={city} />

  <FaqSection items={FAQ_ITEMS} heading={`Common questions about buying in ${cityInfo.name}`} />

  <CrossLinksBand
    brandSlug="toyota"
    brandName="Japanese cars"
    currentCitySlug={city!}
    citiesList={TIER_1_CITIES}
  />
</BaseLayout>
