---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogImage?: string;
  schemaLD?: object | object[];
}

const {
  title,
  description,
  canonical,
  ogImage,
  schemaLD,
} = Astro.props;

// Long titles drop the redundant " — japanauto.ca" suffix so the SERP <title>
// doesn't truncate; the brand still shows in og:site_name and og:title.
const pageTitle = title.length > 65 && title.endsWith(' — japanauto.ca')
  ? title.slice(0, -' — japanauto.ca'.length)
  : title;

// Absolute URL — Open Graph / Twitter reject relative image paths.
const ogImageUrl = new URL(ogImage ?? '/og-default.png', 'https://japanauto.ca').href;

const extraGraph = schemaLD ? (Array.isArray(schemaLD) ? schemaLD : [schemaLD]) : [];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://japanauto.ca/#organization',
      name: 'japanauto.ca',
      url: 'https://japanauto.ca',
      logo: 'https://japanauto.ca/logo.svg',
      description:
        'Independent Canadian marketplace for used Japanese cars and salvage-yard donor parts, aggregating AMVIC- and OMVIC-verified dealer listings across Toronto, Montreal, Vancouver, Calgary, Edmonton, and Ottawa.',
      slogan: "Canada's marketplace for used Japanese cars and parts.",
      areaServed: { '@type': 'Country', name: 'Canada' },
      // Topical entities for entity recognition + GEO citability. Keep accurate —
      // these are subjects the marketplace genuinely covers across its content.
      knowsAbout: [
        'Used Japanese cars', 'Toyota', 'Honda', 'Nissan', 'Mazda', 'Subaru',
        'Lexus', 'Acura', 'Infiniti', 'Mitsubishi', 'AMVIC dealer licensing',
        'OMVIC dealer licensing', 'VIN verification', 'Vehicle history reports',
        'JDM imports', 'Salvage and rebuilt titles', 'Used auto parts', 'Donor cars',
      ],
      contactPoint: {
        '@type': 'ContactPoint',
        contactType: 'customer support',
        email: 'support@japanauto.ca',
        telephone: '+1-833-527-2622',
        areaServed: 'CA',
        availableLanguage: ['en'],
      },
    },
    {
      '@type': 'WebSite',
      '@id': 'https://japanauto.ca/#website',
      url: 'https://japanauto.ca',
      name: 'japanauto.ca',
      publisher: { '@id': 'https://japanauto.ca/#organization' },
      inLanguage: 'en-CA',
      // NOTE: a SearchAction (sitelinks searchbox) was intentionally removed —
      // there is no live /search endpoint yet, and declaring an unfulfilled
      // action is the same anti-pattern faqPage() guards against. Re-add it here
      // when /search ships.
    },
    ...extraGraph,
  ],
};
---
<!DOCTYPE html>
<html lang="en-CA">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#FFFFFF" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <!-- Single-locale (en-CA) geo-targeted site: self-referential hreflang +
         x-default. Add fr-ca alternates here if/when French content ships. -->
    <link rel="alternate" hreflang="en-ca" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate icon" href="/favicon.ico" sizes="any" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_CA" />
    <meta property="og:site_name" content="japanauto.ca" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      id="font-css"
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap"
    />
    {/* Async-CSS rel flip lives in a script (not an onload= attribute) so the
        CSP can stay free of 'unsafe-inline'/'unsafe-hashes'. Keep this byte-
        identical across BaseLayout/DealerLayout/AuthLayout — it dedupes to a
        single hash in the build-time CSP manifest. */}
    <script is:inline>(function(){var l=document.getElementById('font-css');if(l)l.addEventListener('load',function(){l.rel='stylesheet'},{once:true});})();</script>
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap" />
    </noscript>

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd).replace(/</g, '\\u003c')} />
  </head>
  <body>
    <slot name="navbar" />
    <main>
      <slot />
    </main>
    <slot name="footer" />
    <slot name="sticky-bar" />
    <slot name="menu-drawer" />
    <slot name="city-picker" />
    <slot name="filter-dialogs" />
    <script is:inline>
      window.setCityCookie = function (slug, province) {
        var yr = 60 * 60 * 24 * 365;
        document.cookie = "jc_city=" + slug + "; max-age=" + yr + "; path=/; samesite=lax; secure";
        document.cookie = "jc_province=" + province + "; max-age=" + yr + "; path=/; samesite=lax; secure";
        window.location.assign("/" + slug + "/");
      };
      // Delegated replacement for onclick= attributes (blocked under a CSP
      // without 'unsafe-inline'): [data-open-modal] opens the <dialog> with
      // that id; [data-set-city] persists the city hint and navigates.
      document.addEventListener("click", function (e) {
        var el = e.target instanceof Element ? e.target.closest("[data-open-modal],[data-set-city]") : null;
        if (!el) return;
        var modalId = el.getAttribute("data-open-modal");
        if (modalId) {
          var dlg = document.getElementById(modalId);
          if (dlg && typeof dlg.showModal === "function") dlg.showModal();
          return;
        }
        window.setCityCookie(el.getAttribute("data-set-city"), el.getAttribute("data-set-province") || "");
      });
    </script>
  </body>
</html>
