---
import '../styles/global.css';
import Wordmark from '../components/atoms/Wordmark.astro';

interface Props {
  title: string;
  canonical: string;
  activeTab: 'dashboard' | 'listings' | 'donors' | 'profile';
}
const { title, canonical, activeTab } = Astro.props;
const description = 'Dealer portal — japanauto.ca';
// Cloudflare Images delivery hash — inlined at build time via astro.config.mjs
// vite.define so client JS can build `imagedelivery.net/<hash>/<id>/<variant>`
// URLs without a runtime fetch.
const cfAccountHash = (import.meta.env.PUBLIC_CLOUDFLARE_ACCOUNT_HASH ?? '') as string;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#FFFFFF" />
    <meta name="cf-account-hash" content={cfAccountHash} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="canonical" href={canonical} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      id="font-css"
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap"
    />
    {/* Keep byte-identical with BaseLayout's copy — dedupes to one CSP hash. */}
    <script is:inline>(function(){var l=document.getElementById('font-css');if(l)l.addEventListener('load',function(){l.rel='stylesheet'},{once:true});})();</script>
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap" />
    </noscript>
  </head>
  <body class="dealer-body">
    <header class="dealer-header">
      <a href="/" style="display:inline-flex;align-items:center">
        <Wordmark size={20} />
      </a>
      <div style="display:flex;align-items:center;gap:12px">
        <a
          data-plan-badge
          href="/dealer/profile/"
          style="display:none;align-items:center;font-size:12px;font-weight:500;padding:3px 10px;border-radius:999px;text-decoration:none"
        ></a>
        <a href="/dealer/logout/" class="dealer-logout-link">Sign out</a>
      </div>
    </header>
    <nav class="dealer-tabs" aria-label="Dealer navigation">
      <a
        href="/dealer/dashboard/"
        class:list={['dealer-tab', { active: activeTab === 'dashboard' }]}
      >Dashboard</a>
      <a
        href="/dealer/listings/"
        data-tab-listings
        class:list={['dealer-tab', { active: activeTab === 'listings' }]}
      >Listings</a>
      <a
        href="/dealer/donors/"
        data-tab-donors
        class:list={['dealer-tab', { active: activeTab === 'donors' }]}
        style="display:none"
      >Donors</a>
      <a
        href="/dealer/profile/"
        class:list={['dealer-tab', { active: activeTab === 'profile' }]}
      >Profile</a>
    </nav>
    <main class="dealer-main">
      <slot />
    </main>

    <script is:inline>
      (async function () {
        // Single fetch + sessionStorage cache. The layout renders a Listings
        // tab by default; swap to Donors once we know the dealer.type, and
        // renders the plan badge from entitlements (Feature 5). Doing this
        // client-side avoids turning every dashboard page into SSR.
        try {
          var cached = null;
          try { cached = JSON.parse(sessionStorage.getItem('jc_dealer_meta') || 'null'); } catch (_) {}
          if (cached && cached.type) {
            applyType(cached.type);
            applyBadge(cached.badge);
            return;
          }
          var res = await fetch('/api/dealers/me');
          if (res.status === 401) return; // login redirect handled per-page
          if (!res.ok) return;
          var data = await res.json();
          var type = (data.dealer || data || {}).type;
          var badge = badgeFor(data.entitlements);
          if (type === 'salvage_yard' || type === 'dealer') {
            try { sessionStorage.setItem('jc_dealer_meta', JSON.stringify({ type: type, badge: badge })); } catch (_) {}
            applyType(type);
            applyBadge(badge);
          }
        } catch (_) { /* nav stays in default state */ }

        function badgeFor(ent) {
          if (!ent) return null;
          if (ent.onTrial) return { text: 'Pro trial · ' + ent.trialDaysLeft + 'd left', kind: 'trial' };
          if (ent.tier === 'pro') return { text: 'Pro', kind: 'pro' };
          return { text: 'Free plan', kind: 'free' };
        }

        function applyBadge(badge) {
          var el = document.querySelector('[data-plan-badge]');
          if (!el || !badge) return;
          el.textContent = badge.text;
          if (badge.kind === 'free') {
            el.style.background = 'var(--color-bg-subtle)';
            el.style.color = 'var(--color-ink-muted)';
            el.title = 'Free plan — up to 5 active listings. On Pro, 30% of your subscription funds Facebook ads for your own cars.';
          } else {
            el.style.background = 'var(--color-ink-strong)';
            el.style.color = '#fff';
            el.title = (badge.kind === 'trial' ? 'Pro features free during your trial. ' : 'Pro plan — unlimited listings. ')
              + '30% of the Pro subscription funds Facebook promotion of your live cars.';
          }
          el.style.display = 'inline-flex';
        }

        function applyType(type) {
          var listingsTab = document.querySelector('[data-tab-listings]');
          var donorsTab = document.querySelector('[data-tab-donors]');
          if (type === 'salvage_yard') {
            if (listingsTab) listingsTab.style.display = 'none';
            if (donorsTab) donorsTab.style.display = '';
          } else {
            if (listingsTab) listingsTab.style.display = '';
            if (donorsTab) donorsTab.style.display = 'none';
          }
        }
      })();
    </script>
  </body>
</html>
