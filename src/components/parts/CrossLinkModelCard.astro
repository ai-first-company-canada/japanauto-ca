---
interface Props {
  name: string;
  count: number;
  href: string;
}
const { name, count, href } = Astro.props;
---
<a
  class="card"
  href={href}
  style="width:130px;flex-shrink:0;padding:14px;text-decoration:none;display:flex;flex-direction:column;gap:2px"
>
  <span style="font-size:14px;font-weight:600;color:var(--color-ink-strong)">{name}</span>
  <span class="t-caption ink-muted" style="font-size:10px;font-weight:500;letter-spacing:0.06em;text-transform:uppercase">
    <span class="num">{count}</span> donors
  </span>
</a>
