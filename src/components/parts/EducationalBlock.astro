---
export interface EducationalBullet {
  lead: string;
  body: string;
}

interface Props {
  eyebrow?: string;
  heading: string;
  paragraphs?: string[];
  bullets?: EducationalBullet[];
}
const { eyebrow, heading, paragraphs, bullets } = Astro.props;
---
<section style="padding:0 16px">
  <div style="background:var(--color-bg-subtle);border-radius:12px;padding:20px">
    {eyebrow && (
      <span class="t-caption ink-muted" style="font-size:11px;font-weight:500;letter-spacing:0.06em;text-transform:uppercase;display:block;margin-bottom:4px">
        {eyebrow}
      </span>
    )}
    <h2 class="t-h-s" style="font-size:17px;font-weight:600;margin:0 0 12px;color:var(--color-ink-strong);letter-spacing:-0.005em;line-height:24px">
      {heading}
    </h2>
    {paragraphs && paragraphs.map((p, i) => (
      <p style={`margin:${i === 0 ? '0' : '12px 0 0'};font-size:15px;line-height:23px;color:var(--color-ink-default)`}>
        {p}
      </p>
    ))}
    {bullets && (
      <ul style="margin:0;padding:0;list-style:none">
        {bullets.map((b, i) => (
          <li style={`display:grid;grid-template-columns:14px 1fr;column-gap:8px;margin-top:${i === 0 ? '0' : '12px'};font-size:15px;line-height:23px;color:var(--color-ink-default)`}>
            <span aria-hidden="true" style="color:var(--color-ink-strong);font-weight:700;line-height:23px">•</span>
            <span><strong style="font-weight:600;color:var(--color-ink-strong)">{b.lead}:</strong> {b.body}</span>
          </li>
        ))}
      </ul>
    )}
  </div>
</section>
