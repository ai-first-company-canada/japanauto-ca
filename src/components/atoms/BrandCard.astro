---
interface Props {
  name: string;
  count: number;
  slug: string;
  citySlug?: string;
}
const { name, count, slug, citySlug = 'toronto' } = Astro.props;
const href = `/used-cars/${slug}/${citySlug}/`;
---
<a
  href={href}
  class="card"
  style="display:flex;flex-direction:column;justify-content:center;padding:16px;min-height:80px;gap:4px"
>
  <div class="t-h-s" style="font-size:14px;line-height:20px">{name}</div>
  <div class="t-caption" style="font-size:9px;color:var(--color-ink-muted)">{count} listed</div>
</a>
