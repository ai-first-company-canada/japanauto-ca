---
import Icon from './Icon.astro';

interface Props {
  variant: 'primary' | 'secondary';
  icon: 'phone' | 'mail';
  href: string;
  label?: string;
  size?: 'sm' | 'lg';
  ariaLabel?: string;
}

const { variant, icon, href, label, size = 'lg', ariaLabel } = Astro.props;

const isLg = size === 'lg';
const height = isLg ? 56 : 44;
const iconSize = isLg ? 18 : 18;
const radius = isLg ? 10 : 8;

const baseStyle = `height:${height}px;border-radius:${radius}px;display:flex;align-items:center;justify-content:center;gap:8px;font-size:15px;font-weight:600;text-decoration:none;flex-shrink:0;`;

const widthStyle = isLg ? 'width:100%;' : `width:${height}px;`;

const variantStyle = variant === 'primary'
  ? 'background:var(--color-accent);color:#fff;border:none;'
  : 'background:#fff;color:var(--color-ink-strong);border:1.5px solid var(--color-ink-strong);';

const style = baseStyle + widthStyle + variantStyle;
const computedAria = ariaLabel ?? label ?? (icon === 'phone' ? 'Call' : 'Email');
---
<a href={href} style={style} aria-label={computedAria}>
  <Icon name={icon} size={iconSize} />
  {label && <span>{label}</span>}
</a>
