---
interface Palette {
  top: string;
  bot: string;
  glass: string;
  wheel: string;
  stroke: string;
}

interface Props {
  variant?: string;
  tone?: string;
}

const { variant = 'sedan', tone = 'pearl' } = Astro.props;

const palettes: Record<string, Palette> = {
  pearl:    { top: '#FFFFFF', bot: '#D8D4CB', glass: '#1F2530', wheel: '#0A0A0A', stroke: '#A8A296' },
  midnight: { top: '#3A4250', bot: '#1A1F2A', glass: '#0A0A0A', wheel: '#0A0A0A', stroke: '#0A0A0A' },
  crimson:  { top: '#A33A40', bot: '#5A1A20', glass: '#1A0A0E', wheel: '#0A0A0A', stroke: '#1A0A0E' },
  silver:   { top: '#E0E0E2', bot: '#9A9A9C', glass: '#2A2A2D', wheel: '#0A0A0A', stroke: '#7A7A7C' },
  graphite: { top: '#5A5A5E', bot: '#2A2A2D', glass: '#0A0A0A', wheel: '#0A0A0A', stroke: '#1A1A1C' },
};

const c = palettes[tone] ?? palettes.pearl;
const gid = `featured-grad-${variant}-${tone}`;
---

<svg viewBox="0 0 200 130" preserveAspectRatio="xMidYMid meet" style="width: 100%; height: 100%">
  <defs>
    <linearGradient id={gid} x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color={c.top} />
      <stop offset="100%" stop-color={c.bot} />
    </linearGradient>
  </defs>

  {variant === 'sedan' && (
    <g>
      <path d="M22 95 Q26 78 38 75 L62 70 Q70 56 90 54 L120 54 Q142 58 152 72 L172 78 Q180 82 178 95 L178 108 L22 108 Z" fill={`url(#${gid})`} stroke={c.stroke} stroke-width="0.8" />
      <path d="M68 71 Q72 60 88 58 L120 58 Q138 60 148 73 L148 78 L70 78 Z" fill={c.glass} />
      <path d="M108 60 L108 78" stroke={c.stroke} stroke-width="1.2" />
      <path d="M28 78 L172 78 L170 82 L30 82 Z" fill="#FFFFFF" opacity="0.4" />
      <circle cx="56" cy="108" r="13" fill={c.wheel} />
      <circle cx="56" cy="108" r="6" fill="#3A3A3D" />
      <circle cx="148" cy="108" r="13" fill={c.wheel} />
      <circle cx="148" cy="108" r="6" fill="#3A3A3D" />
    </g>
  )}
  {variant === 'suv' && (
    <g>
      <path d="M20 95 Q22 70 36 68 L58 65 Q64 50 88 48 L130 48 Q150 52 158 66 L176 72 Q184 76 182 95 L182 108 L20 108 Z" fill={`url(#${gid})`} stroke={c.stroke} stroke-width="0.8" />
      <path d="M64 66 Q70 53 88 52 L130 52 Q148 54 156 68 L156 74 L66 74 Z" fill={c.glass} />
      <path d="M105 53 L105 74" stroke={c.stroke} stroke-width="1.2" />
      <path d="M132 53 L132 74" stroke={c.stroke} stroke-width="1.2" />
      <path d="M26 76 L178 76 L176 80 L28 80 Z" fill="#FFFFFF" opacity="0.4" />
      <circle cx="54" cy="108" r="14" fill={c.wheel} />
      <circle cx="54" cy="108" r="7" fill="#3A3A3D" />
      <circle cx="150" cy="108" r="14" fill={c.wheel} />
      <circle cx="150" cy="108" r="7" fill="#3A3A3D" />
    </g>
  )}
</svg>
