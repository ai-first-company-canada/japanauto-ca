---
import Icon from './Icon.astro';

interface Props {
  q: string;
  a?: string;
  aHtml?: string;
  open?: boolean;
}
const { q, a, aHtml, open = false } = Astro.props;
---
<details open={open || undefined} style="border-bottom:1px solid var(--color-divider)">
  <summary style="display:flex;justify-content:space-between;align-items:center;list-style:none;padding:16px 0;cursor:pointer;gap:12px">
    <h3 class="t-h-s" style="font-size:15px;line-height:22px;flex:1">{q}</h3>
    <Icon name="chevronDown" size={18} />
  </summary>
  {aHtml
    ? <p class="t-body-m ink-muted" style="font-size:14px;line-height:22px;padding-bottom:16px" set:html={aHtml} />
    : <p class="t-body-m ink-muted" style="font-size:14px;line-height:22px;padding-bottom:16px">{a}</p>}
</details>
