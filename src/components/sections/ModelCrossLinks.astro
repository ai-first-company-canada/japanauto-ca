---
import Icon from '../atoms/Icon.astro';

interface CrossLink {
  slug: string;
  name: string;
  count: number;
}
interface Props {
  brandSlug: string;
  brandName: string;
  citySlug: string;
  cityName: string;
  currentModelSlug: string;
  crossLinks: CrossLink[];
}
const { brandSlug, brandName, citySlug, cityName, currentModelSlug, crossLinks } = Astro.props;
const others = crossLinks.filter((m) => m.slug !== currentModelSlug);
---
<section class="band-subtle" style="padding:32px 16px">
  <h3 class="t-h-m" style="font-size:18px;margin-bottom:12px">
    Or browse other {brandName} models
  </h3>
  <div style="display:flex;gap:8px;overflow-x:auto;margin:0 -16px;padding:4px 16px 8px">
    {others.map((m) => (
      <a
        href={`/${citySlug}/${brandSlug}/${m.slug}/`}
        class="card"
        style="flex:0 0 auto;min-width:120px;padding:14px;display:flex;flex-direction:column;justify-content:center;min-height:76px;gap:4px"
      >
        <div class="t-h-s" style="font-size:14px;line-height:20px;font-weight:600">{m.name}</div>
        {m.count > 0 && (
          <div class="t-caption" style="font-size:9px;letter-spacing:0.06em">
            <span class="num">{m.count}</span> LISTED
          </div>
        )}
      </a>
    ))}
  </div>
  <a
    href={`/${citySlug}/${brandSlug}/`}
    style="display:flex;align-items:center;justify-content:space-between;padding:16px 0 4px;color:var(--color-ink-strong);font-weight:600;font-size:14px"
  >
    All {brandName} models in {cityName}
    <Icon name="arrowRight" size={16} />
  </a>
</section>
