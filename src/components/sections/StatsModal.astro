---
/**
 * StatsModal — the dealer-cabinet "Statistics" dialog (Feature 1,
 * LAUNCH-PLAN-2026-06). One shared <dialog> per page; rows open it via the
 * global `jcOpenStats(entityType, id, title)` defined below.
 *
 * Data: GET /api/{listings|donors}/:id/stats (owner-gated) — lifetime totals
 * + a 30-day daily series. Everything renders client-side inside the dialog;
 * the market-context block lands here in Phase 2 (Supabase sync).
 *
 * CSP: the script is `is:inline` on a noindex SSG page — hashed at build time
 * by scripts/generate-csp-hashes.mjs like every other cabinet script.
 */
---
<dialog
  id="stats-modal"
  style="border:0;border-radius:12px;padding:0;width:min(480px,calc(100vw - 32px));box-shadow:0 8px 40px rgba(0,0,0,0.18)"
>
  <div style="padding:20px 24px">
    <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:12px;margin-bottom:2px">
      <h2 data-stats-title class="t-h-s" style="font-size:16px;line-height:22px;margin:0">Statistics</h2>
      <button type="button" data-stats-close aria-label="Close"
        style="border:0;background:none;font-size:20px;line-height:1;cursor:pointer;color:var(--color-ink-muted);padding:2px">×</button>
    </div>
    <p data-stats-sub class="t-body-s ink-muted" style="font-size:12px;margin:0 0 16px"></p>

    <div data-stats-loading class="t-body-s ink-muted" style="padding:24px 0;text-align:center">Loading…</div>
    <div data-stats-error class="t-body-s" style="display:none;padding:24px 0;text-align:center;color:var(--color-accent)"></div>

    <div data-stats-body style="display:none">
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:16px">
        <div style="background:var(--color-bg-subtle);border-radius:8px;padding:10px 12px">
          <span class="t-caption" style="display:block;font-size:10px;color:var(--color-ink-muted)">VIEWS</span>
          <span data-stat-views class="num" style="font-size:20px;font-weight:600">—</span>
        </div>
        <div style="background:var(--color-bg-subtle);border-radius:8px;padding:10px 12px">
          <span class="t-caption" style="display:block;font-size:10px;color:var(--color-ink-muted)">CONTACTS</span>
          <span data-stat-contacts class="num" style="font-size:20px;font-weight:600">—</span>
        </div>
        <div style="background:var(--color-bg-subtle);border-radius:8px;padding:10px 12px">
          <span class="t-caption" style="display:block;font-size:10px;color:var(--color-ink-muted)">CONVERSION</span>
          <span data-stat-conversion class="num" style="font-size:20px;font-weight:600">—</span>
        </div>
      </div>

      <div style="margin-bottom:6px;display:flex;justify-content:space-between;align-items:baseline">
        <span class="t-caption" style="font-size:10px;color:var(--color-ink-muted)">VIEWS — LAST 30 DAYS</span>
        <span data-stat-views-30 class="t-body-s num ink-muted" style="font-size:12px"></span>
      </div>
      <div data-stats-chart
        style="display:flex;align-items:flex-end;gap:2px;height:56px;margin-bottom:6px;border-bottom:1px solid var(--color-divider);padding-bottom:1px"></div>
      <p data-stat-sources class="t-body-s ink-muted" style="font-size:11px;line-height:16px;margin:0 0 16px"></p>

      <div data-market-root style="display:none;border-top:1px solid var(--color-divider);padding-top:14px">
        <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:8px">
          <span class="t-caption" style="font-size:10px;letter-spacing:0.04em;color:var(--color-ink-muted)">MARKET CONTEXT — ONLY YOU SEE THIS</span>
          <span data-market-date class="t-body-s ink-muted" style="font-size:10px"></span>
        </div>
        <div data-market-content></div>
        <p class="t-body-s ink-muted" style="font-size:10px;line-height:14px;margin:10px 0 0">
          Asking prices from public listings on other platforms, same model
          ±1 year in your city. Never shown to buyers.
        </p>
      </div>
      <p data-market-note class="t-body-s ink-muted" style="font-size:12px;margin:0">
        Market context for this model arrives with the next update.
      </p>
    </div>
  </div>
</dialog>

<script is:inline>
  (function () {
    var dlg = document.getElementById('stats-modal');
    if (!dlg) return;
    var q = function (sel) { return dlg.querySelector(sel); };

    function show(el, on) { if (el) el.style.display = on ? '' : 'none'; }

    function fmtNum(n) { return Number(n || 0).toLocaleString('en-US'); }

    function utcDayKeys(days) {
      var keys = [];
      var t = Date.now();
      for (var i = days - 1; i >= 0; i--) {
        keys.push(new Date(t - i * 86400000).toISOString().slice(0, 10));
      }
      return keys;
    }

    function renderChart(series) {
      var byDay = {};
      (series || []).forEach(function (r) { byDay[r.day] = r; });
      var keys = utcDayKeys(30);
      var max = 1, sum = 0;
      keys.forEach(function (k) {
        var v = byDay[k] ? Number(byDay[k].views || 0) : 0;
        sum += v;
        if (v > max) max = v;
      });
      var chart = q('[data-stats-chart]');
      chart.innerHTML = '';
      keys.forEach(function (k) {
        var v = byDay[k] ? Number(byDay[k].views || 0) : 0;
        var bar = document.createElement('div');
        var h = v === 0 ? 2 : Math.max(4, Math.round((v / max) * 52));
        bar.style.cssText = 'flex:1;border-radius:2px 2px 0 0;height:' + h +
          'px;background:' + (v === 0 ? 'var(--color-divider)' : 'var(--color-ink-strong)');
        bar.title = k + ': ' + v + ' view' + (v === 1 ? '' : 's');
        chart.appendChild(bar);
      });
      var s30 = q('[data-stat-views-30]');
      if (s30) s30.textContent = fmtNum(sum) + ' total';

      // Traffic-source split over the same 30 days (decision 0016): organic
      // social = boost posts (utm_medium=social), paid = Meta catalog ads.
      var social = 0, paid = 0;
      (series || []).forEach(function (r) {
        social += Number(r.views_social || 0);
        paid += Number(r.views_paid || 0);
      });
      var src = q('[data-stat-sources]');
      if (src) {
        src.textContent = (social + paid) > 0
          ? 'Sources: ' + fmtNum(social) + ' from social posts · ' + fmtNum(paid) +
            ' from ads · ' + fmtNum(Math.max(0, sum - social - paid)) + ' direct & search'
          : '';
      }
    }

    var SOURCE_LABELS = {
      marketplace: 'Facebook Marketplace',
      autotrader: 'AutoTrader',
      kijiji: 'Kijiji',
      dealer_sites: 'dealer websites',
    };
    var KIND_LABELS = {
      dealer: 'Dealer asking prices',
      private: 'Private sellers',
      unknown: 'All sellers',
    };
    function segLabel(seg) {
      var kind = Object.prototype.hasOwnProperty.call(KIND_LABELS, seg.seller_kind)
        ? KIND_LABELS[seg.seller_kind] : seg.seller_kind;
      var src = Object.prototype.hasOwnProperty.call(SOURCE_LABELS, seg.source)
        ? SOURCE_LABELS[seg.source] : seg.source;
      return kind + ' · ' + src;
    }

    function fmtCad(cents) {
      return 'CA$' + Math.round(Number(cents) / 100).toLocaleString('en-US');
    }

    function el(tag, css, text) {
      var node = document.createElement(tag);
      if (css) node.style.cssText = css;
      if (text !== undefined) node.textContent = text;
      return node;
    }

    // Renders the private market block (Feature 1 step 3). All data lands via
    // textContent — nothing from the API is ever parsed as HTML.
    function renderMarket(market) {
      var root = q('[data-market-root]');
      var note = q('[data-market-note]');
      var content = q('[data-market-content]');
      if (!root || !note || !content) return;
      content.innerHTML = '';

      // Donor stats carry no market field; listings may carry an unavailable one.
      if (!market || market.available !== true) {
        show(root, false);
        if (!market) { show(note, false); return; }
        note.textContent = market.reason === 'pro_feature'
          ? 'Market price context is part of Pro. Upgrade to see how your price compares.'
          : 'Market context for this model arrives with the next update.';
        show(note, true);
        return;
      }

      var segments = market.segments || market.sources || [];
      if (!segments.length) { // defensive: never show an empty frame
        show(root, false);
        note.textContent = 'Market context for this model arrives with the next update.';
        show(note, true);
        return;
      }

      show(note, false);
      var dateEl = q('[data-market-date]');
      if (dateEl) dateEl.textContent = market.computed_on ? 'as of ' + market.computed_on : '';

      // Primary segment = the dealer's real competitive field (other dealers'
      // asks); private/unknown segments render as compact context lines below
      // — never blended into one median (scraper contract 2026-06-12).
      var primary = null;
      for (var i = 0; i < segments.length; i++) {
        if (segments[i].seller_kind === 'dealer' || segments[i].seller_kind === undefined) { primary = segments[i]; break; }
      }
      if (!primary) primary = segments[0];

      [primary].forEach(function (src) {
        var buckets = src.buckets || [];
        var byBucket = {};
        buckets.forEach(function (b) { byBucket[b.bucket] = b; });
        // The comparison row: the listing's own mileage bucket, falling back
        // to the all-mileage pool when the bucket is empty.
        var own = byBucket[market.listing_bucket];
        var pool = (own && own.n_active > 0) ? own : byBucket['all'];

        content.appendChild(el('div',
          'font-size:11px;font-weight:600;color:var(--color-ink-strong);margin:10px 0 6px',
          src.seller_kind ? segLabel(src) : (Object.prototype.hasOwnProperty.call(SOURCE_LABELS, src.source) ? SOURCE_LABELS[src.source] : src.source)));

        if (pool && pool.n_active > 0 && pool.p50_cents != null && pool.p50_cents > 0) {
          var diff = (market.price_cents - pool.p50_cents) / pool.p50_cents * 100;
          var phrase = Math.abs(diff) < 2 ? 'right at the market median'
            : Math.round(Math.abs(diff)) + '% ' + (diff > 0 ? 'above' : 'below') + ' the market median';
          var poolName = (pool === own)
            ? 'same mileage (' + market.listing_bucket + ')'
            : 'all mileages';
          content.appendChild(el('p', 'font-size:13px;line-height:19px;margin:0 0 8px',
            'Your price ' + fmtCad(market.price_cents) + ' is ' + phrase +
            ' of ' + fmtCad(pool.p50_cents) + ' (' + poolName + ', ' +
            pool.n_active + ' active listing' + (pool.n_active === 1 ? '' : 's') + ').'));
        }

        // Deficit signal — few or no comparable cars on the market right now.
        // The view emits no row for an empty bucket, so "row absent while the
        // model has market rows at all" is the common zero-supply shape.
        if (!own && byBucket['all']) {
          content.appendChild(el('p',
            'font-size:12px;line-height:17px;margin:0 0 8px;color:var(--color-ink-strong);font-weight:600',
            'No similar cars (' + market.listing_bucket + ') listed in your city right now — demand may meet no supply but yours.'));
        } else if (own && own.n_active === 0) {
          content.appendChild(el('p',
            'font-size:12px;line-height:17px;margin:0 0 8px;color:var(--color-ink-strong);font-weight:600',
            'No similar cars (' + market.listing_bucket + ') listed in your city right now — demand may meet no supply but yours.'));
        } else if (own && own.n_active > 0 && own.n_active <= 3) {
          content.appendChild(el('p',
            'font-size:12px;line-height:17px;margin:0 0 8px;color:var(--color-ink-strong);font-weight:600',
            'Only ' + own.n_active + ' similar car' + (own.n_active === 1 ? '' : 's') +
            ' (' + market.listing_bucket + ') on the market in your city — scarce supply.'));
        }

        // Compact per-bucket table: bucket | active | p25–p75 (median).
        var grid = el('div', 'display:flex;flex-direction:column;gap:2px;margin-bottom:4px');
        buckets.forEach(function (b) {
          if (b.bucket === 'all' && buckets.length > 1) return; // shown via comparison line
          var isOwn = b.bucket === market.listing_bucket;
          var row = el('div',
            'display:flex;justify-content:space-between;gap:8px;font-size:12px;line-height:18px;padding:3px 8px;border-radius:6px' +
            (isOwn ? ';background:var(--color-bg-subtle);font-weight:600' : ''));
          row.appendChild(el('span', 'color:var(--color-ink-muted)' + (isOwn ? ';color:var(--color-ink-strong)' : ''),
            b.bucket + (isOwn ? ' · yours' : '')));
          var right = (b.n_active > 0 && b.p25_cents != null && b.p75_cents != null)
            ? fmtCad(b.p25_cents) + '–' + fmtCad(b.p75_cents) + ' · ' + b.n_active + ' active'
            : (b.n_active > 0 ? b.n_active + ' active · no price data' : 'no active listings');
          row.appendChild(el('span', 'font-variant-numeric:tabular-nums', right));
          grid.appendChild(row);
        });
        content.appendChild(grid);

        // Liquidity: median days listed (appears after ~a week of cadence).
        var daysSrc = (own && own.median_days_listed != null) ? own
          : (byBucket['all'] && byBucket['all'].median_days_listed != null ? byBucket['all'] : null);
        if (daysSrc) {
          content.appendChild(el('p', 'font-size:11px;line-height:16px;margin:4px 0 0;color:var(--color-ink-muted)',
            'Similar cars leave the market in ~' + daysSrc.median_days_listed + ' days (median).'));
        }
      });

      // Other segments (private / other platforms): one honest line each,
      // with the spread vs the primary (dealer) median when both exist.
      var primAll = null;
      (primary.buckets || []).forEach(function (b) { if (b.bucket === 'all') primAll = b; });
      segments.forEach(function (seg) {
        if (seg === primary) return;
        if (seg.seller_kind === 'unknown' && segments.length > 1) return; // noise once real kinds exist
        var all = null, ownB = null;
        (seg.buckets || []).forEach(function (b) {
          if (b.bucket === 'all') all = b;
          if (b.bucket === market.listing_bucket) ownB = b;
        });
        var b = (ownB && ownB.n_active > 0 && ownB.p50_cents) ? ownB : all;
        if (!b || !b.n_active || !b.p50_cents) return;
        var line = segLabel(seg) + ': median ' + fmtCad(b.p50_cents) + ' · ' +
          b.n_active + ' listed';
        if (primAll && primAll.p50_cents > 0) {
          var d = Math.round((b.p50_cents - primAll.p50_cents) / primAll.p50_cents * 100);
          if (d !== 0) line += ' — ' + Math.abs(d) + '% ' + (d > 0 ? 'above' : 'below') + ' dealer asks';
        }
        content.appendChild(el('p',
          'font-size:12px;line-height:17px;margin:8px 0 0;color:var(--color-ink-muted)', line));
      });

      show(root, true);
    }

    // Guards against a stale response landing after the modal was reopened
    // for another row (open A → close → open B; A resolves last).
    var openSeq = 0;

    window.jcOpenStats = async function (entityType, id, title) {
      var seq = ++openSeq;
      var apiBase = entityType === 'listing' ? '/api/listings/' : '/api/donors/';
      q('[data-stats-title]').textContent = title || 'Statistics';
      q('[data-stats-sub]').textContent = '';
      show(q('[data-stats-loading]'), true);
      show(q('[data-stats-error]'), false);
      show(q('[data-stats-body]'), false);
      dlg.showModal();

      try {
        var res = await fetch(apiBase + encodeURIComponent(id) + '/stats');
        if (!res.ok) throw new Error('HTTP ' + res.status);
        var d = await res.json();
        if (seq !== openSeq) return; // a newer open superseded this request

        q('[data-stat-views]').textContent = fmtNum(d.totals.views);
        q('[data-stat-contacts]').textContent = fmtNum(d.totals.contacts);
        var conv = d.totals.views > 0
          ? ((d.totals.contacts / d.totals.views) * 100).toFixed(1) + '%'
          : '—';
        q('[data-stat-conversion]').textContent = conv;

        var days = Math.max(0, Math.floor((Date.now() / 1000 - d.created_at) / 86400));
        var sub;
        if (d.sold_at) {
          sub = 'Sold in ' + Math.max(1, Math.round((d.sold_at - d.created_at) / 86400)) + ' days';
        } else {
          sub = (days === 0 ? 'Listed today' : days + ' day' + (days === 1 ? '' : 's') + ' on market') +
            ' · ' + (d.status || '');
        }
        q('[data-stats-sub]').textContent = sub;

        renderChart(d.series);
        renderMarket(d.market);
        show(q('[data-stats-loading]'), false);
        show(q('[data-stats-body]'), true);
      } catch (e) {
        if (seq !== openSeq) return; // stale failure for a superseded open
        show(q('[data-stats-loading]'), false);
        show(q('[data-stats-body]'), false);
        var err = q('[data-stats-error]');
        err.textContent = 'Failed to load statistics (' + e.message + ').';
        show(err, true);
      }
    };

    q('[data-stats-close]').addEventListener('click', function () { dlg.close(); });
    dlg.addEventListener('click', function (e) {
      // click on the backdrop (outside the inner padding box) closes
      if (e.target === dlg) dlg.close();
    });
  })();
</script>
