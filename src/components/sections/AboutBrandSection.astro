---
interface Props {
  title: string;
  paragraphs: string[];
}
const { title, paragraphs } = Astro.props;
---
<section class="band-subtle" style="padding:40px 16px">
  <h3 class="t-h-l" style="font-size:22px;margin-bottom:16px;letter-spacing:-0.01em">{title}</h3>
  {paragraphs.map((p) => (
    <p
      class="t-body-m"
      style="font-size:15px;line-height:24px;margin-bottom:16px;color:var(--color-ink-default);text-wrap:pretty"
    >
      {p}
    </p>
  ))}
</section>
