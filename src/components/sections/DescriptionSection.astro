---
interface Props {
  paragraphs: string[];
}
const { paragraphs } = Astro.props;
---
<section style="padding:32px 16px 0">
  <h2 class="t-h-s" style="font-size:18px;font-weight:600;margin:0;color:var(--color-ink-strong)">
    Description
  </h2>
  {paragraphs.map((p) => (
    <p style="margin-top:12px;font-size:14px;line-height:21px;color:var(--color-ink-default)">{p}</p>
  ))}
</section>
