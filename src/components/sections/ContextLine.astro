---
interface Props {
  cityName?: string;
  count?: number;
  dealers?: number;
}
const {
  cityName = 'Canada',
  count = 0,
  dealers = 0,
} = Astro.props;
const countStr = count.toLocaleString('en-US');
---
<div style="padding:12px 16px 8px">
  <p class="t-body-s ink-muted">
    <span class="num">{countStr}</span>
    Japanese cars from
    <span class="num">{dealers}</span>
    dealers in {cityName} · Updated today
  </p>
</div>
