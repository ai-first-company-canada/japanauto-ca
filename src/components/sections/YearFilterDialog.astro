---
import Icon from '../atoms/Icon.astro';

const years: Array<{ y: number; count: number; disabled?: boolean }> = [
  { y: 2026, count: 0, disabled: true },
  { y: 2025, count: 2 },
  { y: 2024, count: 4 },
  { y: 2023, count: 5 },
  { y: 2022, count: 3 },
  { y: 2021, count: 2 },
  { y: 2020, count: 1 },
  { y: 2019, count: 1 },
  { y: 2018, count: 0, disabled: true },
];
---
<dialog id="year-filter" class="dialog-fullscreen" aria-label="Filter by year">
  <form method="dialog" style="margin:0;display:flex;flex-direction:column;height:100%">
    <div class="sheet-handle"></div>
    <div style="display:flex;justify-content:space-between;align-items:center;padding:4px 16px 12px">
      <h3 class="t-h-m" style="font-size:17px">Year</h3>
      <button class="icon-btn" type="submit" aria-label="Close year filter">
        <Icon name="close" size={20} />
      </button>
    </div>
    <div style="padding:0 16px 8px">
      <p class="t-body-s ink-muted" style="font-size:12px">Select one or more model years</p>
    </div>
    <div class="sheet-scroll" style="border-top:1px solid var(--color-divider);margin:0 16px">
      {years.map(({ y, count, disabled }) => (
        <label
          class="row"
          style={`padding:14px 0;${disabled ? 'opacity:0.4;cursor:not-allowed' : ''}`}
        >
          <input
            type="checkbox"
            name="year"
            value={y}
            disabled={disabled}
            style="position:absolute;opacity:0;pointer-events:none"
          />
          <span class="checkbox" aria-hidden="true"></span>
          <span class="row-label" style="font-size:16px">{y}</span>
          <span class="row-count">
            {disabled ? 'No listings' : `${count} listing${count === 1 ? '' : 's'}`}
          </span>
        </label>
      ))}
    </div>
    <div class="sheet-action">
      <div style="display:flex;gap:12px">
        <button
          class="btn btn-secondary"
          type="reset"
          style="flex:0 0 auto;height:48px;padding:0 16px"
        >
          Clear
        </button>
        <button
          class="btn btn-primary btn-block"
          type="submit"
          style="flex:1;height:48px"
        >
          Apply
        </button>
      </div>
    </div>
  </form>
</dialog>
