---
import Icon from '../atoms/Icon.astro';

const years: Array<{ y: number; count: number; disabled?: boolean }> = [
  { y: 2026, count: 0, disabled: true },
  { y: 2025, count: 2 },
  { y: 2024, count: 4 },
  { y: 2023, count: 5 },
  { y: 2022, count: 3 },
  { y: 2021, count: 2 },
  { y: 2020, count: 1 },
  { y: 2019, count: 1 },
  { y: 2018, count: 0, disabled: true },
];
---
<dialog id="year-filter" class="dialog-fullscreen" aria-label="Filter by year">
  <form method="dialog" style="margin:0;display:flex;flex-direction:column;height:100%">
    <div class="sheet-handle"></div>
    <div style="display:flex;justify-content:space-between;align-items:center;padding:4px 16px 12px">
      <h3 class="t-h-m" style="font-size:17px">Year</h3>
      <button class="icon-btn" type="submit" aria-label="Close year filter">
        <Icon name="close" size={20} />
      </button>
    </div>
    <div style="padding:0 16px 8px">
      <p class="t-body-s ink-muted" style="font-size:12px">Select one or more model years</p>
    </div>
    <div class="sheet-scroll" style="border-top:1px solid var(--color-divider);margin:0 16px">
      {years.map(({ y, count, disabled }) => (
        <label
          class="row"
          style={`padding:14px 0;${disabled ? 'opacity:0.4;cursor:not-allowed' : ''}`}
        >
          <input
            type="checkbox"
            name="year"
            value={y}
            disabled={disabled}
            checked
            data-year-input
            style="position:absolute;opacity:0;pointer-events:none"
          />
          <span class="checkbox" aria-hidden="true"></span>
          <span class="row-label" style="font-size:16px">{y}</span>
          <span class="row-count">
            {disabled ? 'No listings' : `${count} listing${count === 1 ? '' : 's'}`}
          </span>
        </label>
      ))}
    </div>
    <div class="sheet-action">
      <div style="display:flex;gap:12px">
        <button
          class="btn btn-secondary"
          type="button"
          data-clear="year"
          style="flex:0 0 auto;height:48px;padding:0 16px"
        >
          Clear
        </button>
        <button
          class="btn btn-primary btn-block"
          type="button"
          data-apply="year"
          style="flex:1;height:48px"
        >
          Apply
        </button>
      </div>
    </div>
  </form>
</dialog>

<script is:inline>
  (function () {
    var dialog = document.getElementById('year-filter');
    if (!dialog) return;

    function syncFromUrl() {
      var params = new URLSearchParams(window.location.search);
      var raw = params.get('year') || '';
      var picked = raw.split(',').filter(Boolean);
      var inputs = dialog.querySelectorAll('[data-year-input]');
      inputs.forEach(function (cb) {
        if (cb.disabled) {
          cb.checked = false;
          return;
        }
        cb.checked = picked.length === 0 || picked.indexOf(cb.value) !== -1;
      });
    }

    var pill = document.querySelector('[data-pill-key="year"]');
    if (pill) {
      pill.addEventListener('click', syncFromUrl);
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', syncFromUrl);
    } else {
      syncFromUrl();
    }

    var applyBtn = dialog.querySelector('[data-apply="year"]');
    if (applyBtn) {
      applyBtn.addEventListener('click', function () {
        var inputs = dialog.querySelectorAll('[data-year-input]:not([disabled])');
        var checked = [];
        var total = 0;
        inputs.forEach(function (cb) {
          total++;
          if (cb.checked) checked.push(cb.value);
        });
        var params = new URLSearchParams(window.location.search);
        if (checked.length === 0 || checked.length === total) {
          params.delete('year');
        } else {
          params.set('year', checked.join(','));
        }
        var qs = params.toString().replaceAll('%2C', ',');
        var newUrl = window.location.pathname + (qs ? '?' + qs : '');
        window.history.replaceState({}, '', newUrl);
        dialog.close();
        if (window.syncFilterPills) window.syncFilterPills();
        if (window.applyCatalogFilters) window.applyCatalogFilters();
      });
    }

    var clearBtn = dialog.querySelector('[data-clear="year"]');
    if (clearBtn) {
      clearBtn.addEventListener('click', function () {
        var inputs = dialog.querySelectorAll('[data-year-input]:not([disabled])');
        inputs.forEach(function (cb) { cb.checked = true; });
      });
    }
  })();
</script>
