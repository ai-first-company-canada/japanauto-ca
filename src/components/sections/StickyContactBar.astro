---
import ListingPhoto, { type ListingPhotoTone, type ListingPhotoFraming } from '../atoms/ListingPhoto.astro';
import Icon from '../atoms/Icon.astro';
import type { CatalogListing } from '../../data/catalog-stubs';
import type { DealerProfile } from '../../data/dealer-stubs';

interface Photo {
  tone: ListingPhotoTone;
  framing: ListingPhotoFraming;
}

interface Props {
  listing: CatalogListing;
  dealer: DealerProfile;
  photo: Photo;
}

const { listing, dealer, photo } = Astro.props;
const priceStr = listing.price.toLocaleString('en-US');
---
<div class="sticky-contact-bar" data-sticky-bar role="region" aria-label="Contact dealer">
  <div class="sticky-contact-bar__inner">
    <div class="sticky-contact-bar__photo">
      <ListingPhoto tone={photo.tone} framing={photo.framing} />
    </div>
    <div class="sticky-contact-bar__text">
      <p class="sticky-contact-bar__title">
        {listing.year} {listing.model} {listing.trim}
      </p>
      <p class="sticky-contact-bar__price">CA${priceStr}</p>
    </div>
    <a
      href={`tel:${dealer.phoneTel}`}
      class="sticky-contact-bar__call"
      aria-label="Call dealer"
    >
      <Icon name="phone" size={18} />
      <span>Call</span>
    </a>
  </div>
</div>

<script is:inline>
  (function () {
    if (!('IntersectionObserver' in window)) return;
    var bar = document.querySelector('[data-sticky-bar]');
    var trigger = document.querySelector('[data-sticky-trigger]');
    if (!bar || !trigger) return;
    bar.classList.add('sticky-bar-hidden');
    var obs = new IntersectionObserver(function (entries) {
      for (var i = 0; i < entries.length; i++) {
        var e = entries[i];
        if (e.boundingClientRect.top < window.innerHeight * 0.4) {
          bar.classList.remove('sticky-bar-hidden');
        } else {
          bar.classList.add('sticky-bar-hidden');
        }
      }
    }, { threshold: [0, 1] });
    obs.observe(trigger);
  })();
</script>
