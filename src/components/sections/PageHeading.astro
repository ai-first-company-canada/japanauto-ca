---
interface Props {
  title: string;
  subtitle: string;
}
const { title, subtitle } = Astro.props;
---
<section style="padding:12px 16px 20px">
  <h2 class="t-display-m" style="font-size:28px;line-height:34px;letter-spacing:-0.015em;text-wrap:balance">
    {title}
  </h2>
  <p class="t-body-s ink-muted" style="margin-top:8px;font-size:13px" set:html={subtitle} />
</section>
