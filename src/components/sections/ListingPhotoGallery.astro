---
import ListingPhoto, { type ListingPhotoTone, type ListingPhotoFraming } from '../atoms/ListingPhoto.astro';

interface Photo {
  tone: ListingPhotoTone;
  framing: ListingPhotoFraming;
}

interface Props {
  photos: Photo[];
  title: string;
}

const { photos, title } = Astro.props;
const main = photos[0]!;
---
<section style="margin-top:16px;position:relative">
  <div
    role="img"
    aria-label={`${title} — main photo`}
    style="width:100%;aspect-ratio:4 / 3;background:var(--color-bg-muted);position:relative;overflow:hidden"
  >
    <ListingPhoto tone={main.tone} framing={main.framing} />

    <button
      type="button"
      class="photo-main-button"
      aria-label="View all photos"
      onclick="document.getElementById('photo-lightbox').showModal()"
    ></button>

    <div style="position:absolute;left:0;right:0;bottom:12px;display:flex;justify-content:center;gap:5px;pointer-events:none">
      {photos.map((_, i) => (
        <span style={`width:6px;height:6px;border-radius:3px;background:${i === 0 ? 'var(--color-accent)' : 'rgba(140,140,140,0.6)'}`}></span>
      ))}
    </div>

    <button
      type="button"
      class="photo-counter-overlay"
      onclick="document.getElementById('photo-lightbox').showModal()"
    >
      {photos.length} photos · Tap to view all
    </button>
  </div>
</section>
