---
import Icon from '../atoms/Icon.astro';

const options: Array<{ k: string; label: string; count: number }> = [
  { k: 'any',    label: 'Any mileage',          count: 18 },
  { k: '0-25',   label: 'Under 25,000 km',      count: 2 },
  { k: '25-50',  label: '25,000 — 50,000 km',   count: 4 },
  { k: '50-100', label: '50,000 — 100,000 km',  count: 8 },
  { k: '100+',   label: 'Over 100,000 km',      count: 4 },
];
---
<dialog id="mileage-filter" class="dialog-fullscreen" aria-label="Filter by mileage">
  <form method="dialog" style="margin:0;display:flex;flex-direction:column;height:100%">
    <div class="sheet-handle"></div>
    <div style="display:flex;justify-content:space-between;align-items:center;padding:4px 16px 12px">
      <h3 class="t-h-m" style="font-size:17px">Mileage</h3>
      <button class="icon-btn" type="submit" aria-label="Close mileage filter">
        <Icon name="close" size={20} />
      </button>
    </div>
    <div style="padding:0 16px 8px">
      <p class="t-body-s ink-muted" style="font-size:12px">Pick one range</p>
    </div>
    <div class="sheet-scroll" style="border-top:1px solid var(--color-divider);margin:0 16px">
      {options.map((o, i) => (
        <label class="row" style="padding:14px 0">
          <input
            type="radio"
            name="mileage"
            value={o.k}
            checked={i === 0}
            style="position:absolute;opacity:0;pointer-events:none"
          />
          <span class="radio" aria-hidden="true"></span>
          <span class="row-label" style="font-size:16px">{o.label}</span>
          <span class="row-count">
            {o.count} listing{o.count === 1 ? '' : 's'}
          </span>
        </label>
      ))}

      <div style="padding-top:24px;padding-bottom:12px">
        <p class="t-caption" style="font-size:11px;margin-bottom:12px">Or set a custom range</p>
        <div style="display:flex;gap:12px">
          <div style="flex:1">
            <label class="t-body-s ink-muted" style="font-size:12px;display:block;margin-bottom:6px" for="mileage-min">Min km</label>
            <input id="mileage-min" name="km_min" inputmode="numeric" class="input" placeholder="0" style="height:44px" />
          </div>
          <div style="flex:1">
            <label class="t-body-s ink-muted" style="font-size:12px;display:block;margin-bottom:6px" for="mileage-max">Max km</label>
            <input id="mileage-max" name="km_max" inputmode="numeric" class="input" placeholder="200,000" style="height:44px" />
          </div>
        </div>
      </div>
    </div>
    <div class="sheet-action">
      <div style="display:flex;gap:12px">
        <button
          class="btn btn-secondary"
          type="reset"
          style="flex:0 0 auto;height:48px;padding:0 16px"
        >
          Clear
        </button>
        <button
          class="btn btn-primary btn-block"
          type="submit"
          style="flex:1;height:48px"
        >
          Apply
        </button>
      </div>
    </div>
  </form>
</dialog>
